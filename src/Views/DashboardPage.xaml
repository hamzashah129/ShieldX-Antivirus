<Page x:Class="ShieldX.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ShieldX.Views"
      xmlns:models="clr-namespace:ShieldX.Models"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="950"
      Title="Dashboard"
      Background="{DynamicResource AppBg}">

    <Page.Resources>
        <!-- Professional Card Style with Shadow and Hover Effect -->
        <Style x:Key="ProfessionalCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D3F4E"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.15" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">
            <!-- Welcome Header - Professional Design -->
            <Border Style="{StaticResource ProfessionalCard}" Margin="0,0,0,28" Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Welcome to ShieldX Professional" FontSize="28" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                        <TextBlock Text="Your system is protected with real-time monitoring active" FontSize="14"
                                 Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,0" Opacity="0.80"/>
                    </StackPanel>

                    <Border Grid.Column="1" Width="96" Height="96" CornerRadius="48"
                           Background="{DynamicResource AccentClr}" Margin="40,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.25" Color="#00D4FF"/>
                        </Border.Effect>
                        <TextBlock Text="🛡️" FontSize="52" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Stats Cards Row 1 - Professional Grid -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Threats Found Card -->
                <Border Style="{StaticResource ProfessionalCard}" Margin="0,0,6,0" Padding="24" Grid.Column="0">
                    <StackPanel>
                        <TextBlock Text="THREATS DETECTED" FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                 Margin="0,0,0,14" FontWeight="SemiBold" Opacity="0.75"/>
                        <TextBlock x:Name="ThreatsFoundText" Text="{Binding TotalThreatsFound, Source={x:Static models:AppState.Instance}}" 
                                 FontSize="36" FontWeight="Bold" Foreground="#FF6B6B" Margin="0,0,0,6"/>
                        <TextBlock Text="Detected and quarantined" FontSize="12" Foreground="{DynamicResource TextSecondary}" 
                                 Opacity="0.85" FontWeight="Normal"/>
                    </StackPanel>
                </Border>

                <!-- Files Scanned Card -->
                <Border Style="{StaticResource ProfessionalCard}" Margin="3,0" Padding="24" Grid.Column="1">
                    <StackPanel>
                        <TextBlock Text="FILES SCANNED" FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                 Margin="0,0,0,14" FontWeight="SemiBold" Opacity="0.75"/>
                        <TextBlock x:Name="FilesScannedText" Text="{Binding TotalFilesScanned, Source={x:Static models:AppState.Instance}}" 
                                 FontSize="36" FontWeight="Bold" Foreground="#00D4D4" Margin="0,0,0,6"/>
                        <TextBlock Text="Total analyzed files" FontSize="12" Foreground="{DynamicResource TextSecondary}" 
                                 Opacity="0.85" FontWeight="Normal"/>
                    </StackPanel>
                </Border>

                <!-- Quarantined Card -->
                <Border Style="{StaticResource ProfessionalCard}" Margin="3,0" Padding="24" Grid.Column="2">
                    <StackPanel>
                        <TextBlock Text="ITEMS QUARANTINED" FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                 Margin="0,0,0,14" FontWeight="SemiBold" Opacity="0.75"/>
                        <TextBlock x:Name="QuarantinedText" Text="{Binding QuarantinedCount, Source={x:Static models:AppState.Instance}}" 
                                 FontSize="36" FontWeight="Bold" Foreground="#FFB800" Margin="0,0,0,6"/>
                        <TextBlock Text="Isolated threats" FontSize="12" Foreground="{DynamicResource TextSecondary}" 
                                 Opacity="0.85" FontWeight="Normal"/>
                    </StackPanel>
                </Border>

                <!-- Security Score Card -->
                <Border Style="{StaticResource ProfessionalCard}" Margin="6,0,0,0" Padding="24" Grid.Column="3">
                    <StackPanel>
                        <TextBlock Text="SECURITY SCORE" FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                 Margin="0,0,0,14" FontWeight="SemiBold" Opacity="0.75"/>
                        <TextBlock x:Name="SecurityScoreText" Text="{Binding SecurityScore, Source={x:Static models:AppState.Instance}, StringFormat={}{0}%}" 
                                 FontSize="36" FontWeight="Bold" Foreground="{Binding SecurityScore, Source={x:Static models:AppState.Instance}, Converter={StaticResource ScoreToBrushConverter}}" 
                                 Margin="0,0,0,6"/>
                        <TextBlock Text="System protection level" FontSize="12" Foreground="{DynamicResource TextSecondary}" 
                                 Opacity="0.85" FontWeight="Normal"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- System Health -->
            <Border Style="{StaticResource ProfessionalCard}" Margin="0,0,0,28" Padding="28">
                <StackPanel>
                    <TextBlock Text="System Health &amp; Security Status" FontSize="16" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Overall Protection Status" FontSize="13" FontWeight="SemiBold" 
                                     Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>
                            <ProgressBar x:Name="SystemHealthProgress" Height="8" Value="{Binding SecurityScore, Source={x:Static models:AppState.Instance}}"
                                       Margin="0,0,24,0" Minimum="0" Maximum="100"
                                       Foreground="{Binding SecurityScore, Source={x:Static models:AppState.Instance}, Converter={StaticResource ScoreToBrushConverter}}"
                                       Background="#1A2D3F"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24,0,0,0">
                            <TextBlock x:Name="SystemHealthPercent" 
                                     Text="{Binding SecurityScore, Source={x:Static models:AppState.Instance}, StringFormat={}{0}%}" 
                                     FontSize="24" FontWeight="SemiBold" Foreground="{Binding SecurityScore, Source={x:Static models:AppState.Instance}, Converter={StaticResource ScoreToBrushConverter}}"/>
                            <TextBlock Text="Protected" FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                     HorizontalAlignment="Center" Opacity="0.8" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#1A1F2E" CornerRadius="8" Padding="0" Margin="0,0,0,2">
                        <TextBlock x:Name="LastScanText" Text="{Binding LastScanTime, Source={x:Static models:AppState.Instance}, Converter={StaticResource DateTimeConverter}, StringFormat=Last comprehensive scan: {0}}" 
                                 FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="12,8,12,8" 
                                 Opacity="0.95" FontWeight="Normal"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Resource Monitor -->
            <local:ResourceMonitorWidget Margin="0,0,0,25"/>

            <!-- Real-Time Threat Map -->
            <local:ThreatMapWidget Margin="0,0,0,25" Height="300"/>

            <!-- Active Modules -->
            <Border Style="{StaticResource ProfessionalCard}" Margin="0,0,0,28" Padding="28">
                <StackPanel>
                    <TextBlock Text="Active Protection Modules" FontSize="16" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,18"/>

                    <ItemsControl x:Name="ModulesList" ItemsSource="{Binding Modules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12" Padding="16,14" Background="{DynamicResource CardBg2}"
                                       CornerRadius="10" BorderBrush="#2D3F4E" BorderThickness="1" x:Name="ModuleBorder"
                                       MouseLeftButtonUp="ModuleBorder_MouseLeftButtonUp" Cursor="Hand"
                                       ToolTip="Click to toggle this protection module">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Direction="270"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Icon}" FontSize="18" Margin="0,0,14,0" Opacity="0.9"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" 
                                                     FontSize="13" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                                     Opacity="0.75" FontWeight="Normal"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                                            <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#3D4D5C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Fill" Value="#10B981"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding IsEnabled, StringFormat={}{0}}" FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                                     VerticalAlignment="Center" FontWeight="Normal" Opacity="0.85"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Recent Real-Time Alerts -->
            <Border Style="{StaticResource ProfessionalCard}" Margin="0,0,0,28" Padding="28">
                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Recent Threats Blocked Today" FontSize="16" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ThreatBlockedToday, StringFormat={}{0} blocked today}" 
                                 FontSize="13" Foreground="#FF6B6B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Real-time protection is actively monitoring your system for threats." FontSize="12"
                             Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,18" Opacity="0.80" FontWeight="Normal"/>

                    <ItemsControl x:Name="RecentAlertsList" ItemsSource="{Binding RecentAlerts}" MaxHeight="350">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" Padding="16" Background="{DynamicResource CardBg2}"
                                       CornerRadius="10" BorderThickness="1" BorderBrush="#2D3F4E" x:Name="AlertBorder"
                                       MouseRightButtonUp="AlertBorder_MouseRightButtonUp" Cursor="Hand">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06" Direction="270"/>
                                    </Border.Effect>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="View in Quarantine" Click="ViewQuarantine_Click" Tag="{Binding FileName}"/>
                                            <MenuItem Header="View Details" Click="ViewAlertDetails_Click" Tag="{Binding}"/>
                                            <Separator/>
                                            <MenuItem Header="Dismiss" Click="DismissAlert_Click" Tag="{Binding}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,14,0" Opacity="0.85"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" 
                                                     Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,0,0,3"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Threat}" FontSize="11" Foreground="#FF6B6B" 
                                                         FontWeight="SemiBold" Margin="0,0,12,0"/>
                                                <TextBlock Grid.Column="1" Text="|" FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                                         Opacity="0.4" Margin="0,0,12,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Path}" FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                                         Opacity="0.70" TextTrimming="CharacterEllipsis" FontWeight="Normal"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                            <Border Background="#2D3F4E" CornerRadius="4" Padding="6,3">
                                                <TextBlock Text="{Binding Action}" FontSize="10" Foreground="#10B981" 
                                                         FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Time}" FontSize="10" Foreground="{DynamicResource TextSecondary}" 
                                                     Margin="12,0,0,0" Opacity="0.70" VerticalAlignment="Center" FontWeight="Normal"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoAlertsText" Text="✓ No threats detected - your system is clean." FontSize="13"
                             Foreground="#10B981" Visibility="{Binding HasNoAlerts, Converter={StaticResource BooleanToVisibilityConverter}}"
                             HorizontalAlignment="Center" Margin="0,24,0,0" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <Border Style="{StaticResource ProfessionalCard}" Padding="28">
                <StackPanel>
                    <TextBlock Text="Quick Actions" FontSize="16" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="QuickScanButton" Content="Quick Scan" Margin="0,0,10,0" Padding="18,14"
                               Background="#00D4D4" Foreground="#000000" BorderThickness="0" FontSize="13" FontWeight="SemiBold"
                               Cursor="Hand" Click="QuickScanButton_Click">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" Color="#00D4D4"/>
                            </Button.Effect>
                        </Button>

                        <Button x:Name="FullScanButton" Content="Full Scan" Margin="10,0" Padding="18,14"
                               Background="#6C63FF" Foreground="#FFFFFF" BorderThickness="0" FontSize="13" FontWeight="SemiBold"
                               Cursor="Hand" Click="FullScanButton_Click">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" Color="#6C63FF"/>
                            </Button.Effect>
                        </Button>

                        <Button x:Name="UpdateButton" Content="Update Definitions" Margin="10,0,0,0" Padding="18,14"
                               Background="#10B981" Foreground="#FFFFFF" BorderThickness="0" FontSize="13" FontWeight="SemiBold"
                               Cursor="Hand" Click="UpdateButton_Click">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" Color="#10B981"/>
                            </Button.Effect>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>