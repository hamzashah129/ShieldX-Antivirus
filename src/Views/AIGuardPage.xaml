<Page x:Class="ShieldX.Views.AIGuardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ShieldX.Views"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="950"
      Title="AI Guard"
      Background="{DynamicResource AppBg}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <!-- ROW 1 — Status Hero Card -->
            <Border Style="{StaticResource GlassCard}" Margin="0,0,0,20" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Col 0: Animated Status Indicator + Label -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="14" Height="14" Fill="#00C9A7" Margin="0,0,10,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAIGuardActive}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                            From="1" To="0.4" Duration="0:0:1" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="AI Guard Active" FontSize="18" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Col 1: 4 Metrics Grid -->
                    <UniformGrid Grid.Column="1" Columns="4" HorizontalAlignment="Center" Margin="40,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ProcessesScannedToday}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Scanned Today" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ThreatsBlockedToday}" FontSize="20" FontWeight="Bold"
                                       Foreground="#FF6B6B" HorizontalAlignment="Center"/>
                            <TextBlock Text="Blocked" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding SuspiciousFlagged}" FontSize="20" FontWeight="Bold"
                                       Foreground="#FFA500" HorizontalAlignment="Center"/>
                            <TextBlock Text="Suspicious" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TrainingSamples}" FontSize="20" FontWeight="Bold"
                                       Foreground="#10B981" HorizontalAlignment="Center"/>
                            <TextBlock Text="Training Samples" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </UniformGrid>

                    <!-- Col 2: Toggle Button -->
                    <ToggleButton Grid.Column="2" IsChecked="{Binding IsAIGuardActive}" 
                                  Style="{StaticResource ModernToggle}" Width="50" Height="26"
                                  VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ROW 2 — Status Bar -->
            <TextBlock Text="{Binding StatusText}" FontSize="13" Foreground="{DynamicResource TextSecondary}"
                       Margin="0,5,0,15" FontStyle="Italic"/>

            <!-- ROW 3 — Header + Button -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Recent AI Detections" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"/>
                
                <Button Grid.Column="1" Content="📊 Export Report" Command="{Binding ExportReportCommand}"
                        Padding="14,8" Background="{DynamicResource HoverBg}"
                        Foreground="{DynamicResource TextSecondary}" BorderThickness="1"
                        BorderBrush="{DynamicResource BorderClr}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ROW 4 — ListView of Detections -->
            <Border Style="{StaticResource GlassCard}" MaxHeight="400" Padding="0" Margin="0,0,0,15">
                <ListView ItemsSource="{Binding RecentDetections}" Background="Transparent"
                          BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Time" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TimeText}" Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Process Name" Width="150">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="12"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Threat Class" Width="130">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ThreatClass}" Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Score %" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ScorePercentage}" FontSize="12" FontWeight="Bold"
                                                   Foreground="{Binding ScoreColor}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Action" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Action}" Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{DynamicResource BorderClr}"
                                                BorderThickness="0,0,0,1">
                                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                                  Columns="{TemplateBinding GridView.ColumnCollection}"
                                                                  Margin="0"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Border>

            <!-- ROW 5 — About AI Guard Card -->
            <Border Style="{StaticResource GlassCard}" Padding="20">
                <StackPanel>
                    <TextBlock Text="About AI Guard" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>
                    <TextBlock Text="ShieldX AI Guard uses behavioral heuristic analysis to detect threats in real-time without cloud connectivity. All analysis runs locally on your device."
                               Foreground="{DynamicResource TextSecondary}" FontSize="13" TextWrapping="Wrap"
                               Margin="0,0,0,10" LineHeight="18"/>
                    <TextBlock Text="{Binding ModelVersion}" Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
