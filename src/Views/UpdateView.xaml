<UserControl x:Class="ShieldX.Views.UpdateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- Button hover animation -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Name="border">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="0" Opacity="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                           Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                           To="8" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                           Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                           To="0.3" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                           Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                           To="0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                           Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                           To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Background="{DynamicResource AppBg}"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,30">

            <!-- Header -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="24,16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="⬆ Updates"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                   Margin="0,6,0,0"
                                   Text="Keep ShieldX up to date for the latest protection"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="🔄 Check for Updates"
                            Command="{Binding CheckUpdateCommand}"
                            Padding="16,10"
                            Background="#00E5CC"
                            Foreground="#0D1117"
                            FontWeight="Bold"
                            Style="{StaticResource ModernButtonStyle}"
                            IsEnabled="{Binding IsNotDownloading}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Error state card -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="24" Margin="0,0,0,16"
                    BorderBrush="#EF4444" BorderThickness="1"
                    Visibility="{Binding HasError,
                        Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠" FontSize="20"
                                   Foreground="#EF4444"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Top"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Update Check Failed"
                                       Foreground="#EF4444"
                                       FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="🔄 Retry"
                            Command="{Binding CheckUpdateCommand}"
                            Padding="12,8"
                            Background="#EF4444"
                            Foreground="White"
                            FontWeight="Bold"
                            Style="{StaticResource ModernButtonStyle}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Checking animation -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="40,30" Margin="0,0,0,16"
                    Visibility="{Binding IsChecking,
                        Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Height="4"
                                 Width="300" Background="{DynamicResource HoverBg}"
                                 Foreground="#00E5CC"/>
                    <TextBlock Text="Checking for updates..."
                               Foreground="{DynamicResource TextSecondary}" FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>
            </Border>

            <!-- Current version card -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="24" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App icon -->
                    <Border Grid.Column="0"
                            Width="56" Height="56"
                            CornerRadius="12"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,1">
                                <GradientStop Color="#00E5CC" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🛡" FontSize="26"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- App info -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="ShieldX Professional Antivirus"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Foreground="{DynamicResource TextSecondary}"
                                   FontSize="13" Margin="0,4,0,0">
                            <Run Text="Version "/>
                            <Run Text="{Binding CurrentVersion}" Foreground="#00E5CC" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource TextMuted}"
                                   FontSize="11" Margin="0,3,0,0"
                                   Text="Windows 10/11 · .NET 8 WPF"/>
                    </StackPanel>

                    <!-- Status badge -->
                    <Border Grid.Column="2"
                            CornerRadius="8" Padding="14,8"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="#0D2818"/>
                                <Style.Triggers>
                                    <DataTrigger
                                        Binding="{Binding UpdateAvailable}"
                                        Value="True">
                                        <Setter Property="Background"
                                                Value="#1A150D"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="13" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"
                                            Value="✓ Up to date"/>
                                    <Setter Property="Foreground"
                                            Value="#10B981"/>
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding UpdateAvailable}"
                                            Value="True">
                                            <Setter Property="Text"
                                                    Value="⬆ Update Available"/>
                                            <Setter Property="Foreground"
                                                    Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!-- UPDATE AVAILABLE CARD -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="24" Margin="0,0,0,16"
                    BorderBrush="#F59E0B" BorderThickness="2"
                    Visibility="{Binding UpdateAvailable,
                        Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <!-- Update header -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="⬆"
                                           Foreground="#F59E0B"
                                           FontSize="20"
                                           Margin="0,0,10,0"/>
                                <TextBlock FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}">
                                    <Run Text="Update Available"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Margin="0,0,0,6"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="13">
                                <Run Text="v"/>
                                <Run Text="{Binding CurrentVersion}"/>
                                <Run Text=" → "/>
                                <Run Text="v"/>
                                <Run Text="{Binding LatestVersion}"
                                     Foreground="#10B981" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock Text="{Binding ReleaseDate,
                                           StringFormat='Released: {0:MMMM dd, yyyy}'}"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="11"/>
                        </StackPanel>

                        <!-- Update/Download buttons -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsDownloading,
                                        Converter={StaticResource InverseBoolToVis}}">
                            <Button Content="📥 Download &amp; Install"
                                    Command="{Binding DownloadInstallCommand}"
                                    Padding="16,10" Margin="0,0,8,0"
                                    Background="#F59E0B"
                                    Foreground="{DynamicResource TextPrimary}"
                                    FontWeight="Bold"
                                    Style="{StaticResource ModernButtonStyle}"/>
                            <Button Content="🌐 View Release"
                                    Command="{Binding ViewReleaseCommand}"
                                    Padding="16,10"
                                    Background="{DynamicResource HoverBg}"
                                    Foreground="{DynamicResource TextPrimary}"
                                    Style="{StaticResource ModernButtonStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Download progress -->
                    <Border Background="{DynamicResource AppBg}" CornerRadius="8"
                            Padding="16"
                            Visibility="{Binding IsDownloading,
                                Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Downloading update..."
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="13" FontWeight="Bold"/>
                                <TextBlock Text="{Binding DownloadProgress,
                                               StringFormat='{}{0}%'}"
                                           Foreground="#00E5CC"
                                           FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Value="{Binding DownloadProgress}"
                                         Maximum="100" Height="6"
                                         Background="{DynamicResource HoverBg}">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,0">
                                        <GradientStop Color="#00E5CC"
                                                      Offset="0"/>
                                        <GradientStop Color="#7C3AED"
                                                      Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                            <TextBlock Text="{Binding DownloadStatus}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11" Margin="0,8,0,0"/>
                            <Button Content="Cancel Download"
                                    Command="{Binding CancelDownloadCommand}"
                                    Margin="0,10,0,0"
                                    Padding="12,6"
                                    Background="{DynamicResource HoverBg}"
                                    Foreground="{DynamicResource TextSecondary}"
                                    Style="{StaticResource ModernButtonStyle}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Release notes -->
                    <Border Background="{DynamicResource AppBg}" CornerRadius="8"
                            Padding="16" Margin="0,12,0,0"
                            Visibility="{Binding HasReleaseNotes,
                                Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="📋 What's New"
                                       Foreground="#00E5CC"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding ReleaseNotes}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       LineHeight="18"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- UP TO DATE CARD -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="40,40" Margin="0,0,0,16"
                    Visibility="{Binding IsUpToDate,
                        Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="✅" FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="All installations are up to date."
                               Foreground="{DynamicResource TextPrimary}" FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="12"
                               HorizontalAlignment="Center"
                               TextAlignment="Center">
                        <Run Text="ShieldX Professional v"/>
                        <Run Text="{Binding CurrentVersion}"
                             Foreground="#00E5CC" FontWeight="Bold"/>
                        <Run Text=" is the latest version"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Release history section -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="📜 Release History"
                               Foreground="{DynamicResource TextPrimary}" FontSize="16"
                               FontWeight="Bold" Margin="0,0,0,16"/>

                    <!-- Releases from ViewModel -->
                    <ItemsControl ItemsSource="{Binding ReleaseHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource AppBg}" CornerRadius="8"
                                        Padding="16" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Background="#0D2818"
                                                CornerRadius="6" Padding="10,5"
                                                Margin="0,0,14,0"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Version}"
                                                       Foreground="#00E5CC"
                                                       FontWeight="Bold"
                                                       FontSize="12"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontWeight="Bold"
                                                       FontSize="13"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="12" Margin="0,4,0,0"
                                                       TextWrapping="Wrap"
                                                       LineHeight="18"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Status}"
                                                   Foreground="#10B981"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Top"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Auto-update settings -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="⚙ Update Settings"
                               Foreground="{DynamicResource TextPrimary}" FontSize="16"
                               FontWeight="Bold" Margin="0,0,0,16"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Automatic update checks"
                                       Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       Margin="0,3,0,0"
                                       Text="Check for updates automatically on startup"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding AutoCheckEnabled}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Notify before installing"
                                       Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       Margin="0,3,0,0"
                                       Text="Ask before downloading updates"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding NotifyBeforeInstall}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
