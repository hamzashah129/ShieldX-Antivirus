<Page x:Class="ShieldX.Views.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource AppBg}">

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="📋 Activity Logs"
                    Foreground="{DynamicResource TextPrimary}"
                    FontSize="22" FontWeight="Bold"/>
                <TextBlock
                    Text="Real-time system activity and threat events"
                    Foreground="{DynamicResource TextSecondary}"
                    FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button Content="🔄 Refresh"
                    Command="{Binding RefreshCommand}"
                    Padding="12,8" Margin="0,0,8,0"
                    Background="{DynamicResource HoverBg}"
                    Foreground="{DynamicResource TextSecondary}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderClr}"
                    Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="📤 Export"
                    Command="{Binding ExportCommand}"
                    Padding="12,8" Margin="0,0,8,0"
                    Background="{DynamicResource HoverBg}"
                    Foreground="{DynamicResource TextSecondary}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderClr}"
                    Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="🗑 Clear"
                    Command="{Binding ClearCommand}"
                    Padding="12,8"
                    Background="#1A0D0D"
                    Foreground="#EF4444"
                    BorderThickness="1"
                    BorderBrush="#EF4444"
                    Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBg}"
                CornerRadius="10" Padding="14,10"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Border Background="{DynamicResource InputBg}"
                        CornerRadius="7"
                        BorderBrush="{DynamicResource BorderClr}"
                        BorderThickness="1"
                        Margin="0,0,10,0">
                    <Grid>
                        <TextBox
                            Text="{Binding SearchText,
                                UpdateSourceTrigger=PropertyChanged}"
                            Background="Transparent"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderThickness="0"
                            Padding="10,8" FontSize="12"/>
                        <TextBlock
                            Text="🔍  Search logs..."
                            Foreground="{DynamicResource TextMuted}"
                            FontSize="12" Padding="12,9"
                            IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding SearchText}"
                                            Value="">
                                            <Setter Property="Visibility"
                                                Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Filter buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Content="All"
                        Command="{Binding FilterAllCommand}"
                        Padding="14,7" Margin="0,0,4,0"
                        Background="#0D2818"
                        Foreground="#00E5CC"
                        BorderThickness="0" Cursor="Hand"
                        FontWeight="Bold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="INFO"
                        Command="{Binding FilterInfoCommand}"
                        Padding="14,7" Margin="0,0,4,0"
                        Background="{DynamicResource HoverBg}"
                        Foreground="#A0AEC0"
                        BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="WARNING"
                        Command="{Binding FilterWarningCommand}"
                        Padding="14,7" Margin="0,0,4,0"
                        Background="{DynamicResource HoverBg}"
                        Foreground="#F59E0B"
                        BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="ERROR"
                        Command="{Binding FilterErrorCommand}"
                        Padding="14,7"
                        Background="{DynamicResource HoverBg}"
                        Foreground="#EF4444"
                        BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Logs list -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBg}"
                CornerRadius="12"
                ClipToBounds="True">
            <Grid>
                <!-- Empty state -->
                <StackPanel
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNoLogs}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="📋" FontSize="40"
                        HorizontalAlignment="Center"/>
                    <TextBlock Text="No log entries yet"
                        Foreground="{DynamicResource TextPrimary}"
                        FontSize="16" FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,6"/>
                    <TextBlock
                        Text="Activity will appear here when ShieldX runs"
                        Foreground="{DynamicResource TextSecondary}"
                        FontSize="12"
                        HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Log entries -->
                <ScrollViewer
                    VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasLogs}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding FilteredLogs}"
                                  Padding="16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,2"
                                        Padding="12,8"
                                        CornerRadius="6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter Property="Background"
                                                        Value="{DynamicResource HoverBg}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Time -->
                                        <TextBlock
                                            Text="{Binding TimeText}"
                                            Foreground="{DynamicResource TextMuted}"
                                            FontSize="11"
                                            FontFamily="Consolas"
                                            VerticalAlignment="Center"/>

                                        <!-- Level badge -->
                                        <Border Grid.Column="1"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding LevelBg}"/>
                                            </Border.Background>
                                            <TextBlock
                                                Text="{Binding Level}"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Foreground="{Binding LevelColor, Converter={StaticResource StringToColorBrush}}"/>
                                        </Border>

                                        <!-- Message -->
                                        <TextBlock Grid.Column="2"
                                            Text="{Binding Message}"
                                            Foreground="{DynamicResource TextSecondary}"
                                            FontSize="12"
                                            TextWrapping="Wrap"
                                            VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>