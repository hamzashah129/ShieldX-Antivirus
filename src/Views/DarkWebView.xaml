<Page x:Class="ShieldX.Views.DarkWebView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="{DynamicResource AppBg}"
      Foreground="{DynamicResource TextPrimary}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0">
                <!-- Header -->
                <Border Background="{DynamicResource CardBg}" Padding="30,40,30,30">
                    <StackPanel>
                        <TextBlock Text="🌐 Dark Web Monitor" FontSize="28" FontWeight="Bold" 
                                  Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>
                        <TextBlock Text="Check if your email appears in known data breaches" 
                                  FontSize="14" Foreground="{DynamicResource AccentClr}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Main Content -->
                <Border Padding="30" Margin="0">
                    <StackPanel>
                        <!-- Email Check Section -->
                        <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="30,35" Margin="0,0,0,30"
                               BorderThickness="2" BorderBrush="{DynamicResource AccentClr}">
                            <StackPanel>
                                <!-- Email Input Label -->
                                <TextBlock Text="Email Address" FontSize="14" FontWeight="SemiBold" 
                                          Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>
                                
                                <!-- Email Input Box -->
                                <Border Background="{DynamicResource CardBg}" CornerRadius="10" BorderThickness="2" 
                                       BorderBrush="{DynamicResource AccentClr}" Padding="16,14" Margin="0,0,0,25"
                                       Height="56">
                                    <TextBox x:Name="EmailInput" Text="{Binding EmailInput, UpdateSourceTrigger=PropertyChanged}"
                                            Background="Transparent" Foreground="{DynamicResource TextPrimary}" 
                                            BorderThickness="0" Padding="0" FontSize="14"
                                            VerticalContentAlignment="Center"
                                            KeyDown="EmailInput_KeyDown"
                                            CaretBrush="{DynamicResource AccentClr}"/>
                                </Border>

                                <!-- Check Now Button -->
                                <Button Command="{Binding CheckNowCommand}" Height="52" FontSize="14" 
                                       FontWeight="Bold" Background="#FF00D4AA" Foreground="#FFFFFF"
                                       Cursor="Hand" IsEnabled="{Binding IsChecking, Converter={StaticResource InverseBoolConverter}}"
                                       Margin="0,0,0,20">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="🔍" Margin="0,0,10,0" FontSize="16"/>
                                        <TextBlock Text="Check Now" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>

                                <!-- Loading Indicator -->
                                <Border Visibility="{Binding IsChecking, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Background="{DynamicResource CardBg2}" CornerRadius="8" Padding="15" Margin="0,10,0,0"
                                       BorderThickness="1" BorderBrush="{DynamicResource AccentClr}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="🔄 Checking email database..." Foreground="{DynamicResource TextPrimary}" 
                                                  FontSize="12" TextAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Text="Please wait..." Foreground="{DynamicResource TextSecondary}" 
                                                  FontSize="11" TextAlignment="Center" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Status Message - Success -->
                                <Border Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"
                                       Background="{DynamicResource CardBg2}" CornerRadius="8" Padding="15" Margin="0,15,0,0"
                                       BorderThickness="1" BorderBrush="{DynamicResource AccentClr}">
                                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextPrimary}" 
                                              FontSize="12" TextWrapping="Wrap"
                                              FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Results Section -->
                        <StackPanel Visibility="{Binding LastCheckedEmail, Converter={StaticResource StringToVisibilityConverter}}"
                                   Margin="0,0,0,30">
                            <!-- Clean Status (Green Shield) -->
                            <Border Background="{DynamicResource CardBg2}" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                                   Visibility="{Binding IsEmailClean, Converter={StaticResource BoolToVisibilityConverter}}"
                                   BorderThickness="2" BorderBrush="#FF10B981">
                                <StackPanel>
                                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,15">
                                        <TextBlock Text="✅" FontSize="48" TextAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ResultsText}" Foreground="#FF10B981" FontSize="18" 
                                              FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="Your email address has not been found in known data breaches."
                                              Foreground="{DynamicResource TextSecondary}" FontSize="12" TextAlignment="Center" 
                                              TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Breach Found Status -->
                            <Border Background="{DynamicResource CardBg2}" CornerRadius="12" Padding="20" Margin="0,0,0,20"
                                   Visibility="{Binding HasBreaches, Converter={StaticResource BoolToVisibilityConverter}}"
                                   BorderThickness="1" BorderBrush="#FFFF6B6B">
                                <StackPanel>
                                    <TextBlock Text="{Binding ResultsText}" Foreground="#FFFF6B6B" 
                                              FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock Text="⚠️ Warning: Your email was found in data breach(es)." 
                                              Foreground="#FFFF9999" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- Breach Cards -->
                            <ItemsControl ItemsSource="{Binding Breaches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource CardBg2}" CornerRadius="10" Padding="20" 
                                               Margin="0,0,0,15" BorderThickness="2" 
                                               BorderBrush="#FFFF6B6B">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Breach Details -->
                                                <StackPanel Grid.Column="0">
                                                    <!-- Breach Name and Date -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <TextBlock Text="{Binding Title}" Foreground="#FFFF6B6B" 
                                                                  FontSize="15" FontWeight="SemiBold" Margin="0,0,15,0"/>
                                                        <TextBlock Text="{Binding BreachDateLabel}" Foreground="#FFFF9999" 
                                                                  FontSize="12" VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <!-- Affected Accounts Count -->
                                                    <TextBlock Text="{Binding PwnCountLabel, StringFormat='Affected Accounts: {0}'}" 
                                                              Foreground="#FFFF9999" FontSize="12" Margin="0,0,0,10"/>

                                                    <!-- Exposed Data Types -->
                                                    <TextBlock Text="Data Exposed:" Foreground="#FFFF6B6B" 
                                                              FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <TextBlock Text="{Binding DataClassesLabel}" Foreground="{DynamicResource TextSecondary}" 
                                                              FontSize="11" TextWrapping="Wrap" Margin="0,0,0,0"/>

                                                    <!-- Description (if available) -->
                                                    <TextBlock Text="{Binding Description}" Foreground="#FFFF9999" 
                                                              FontSize="11" TextWrapping="Wrap" Margin="0,12,0,0"
                                                              Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                </StackPanel>

                                                <!-- Risk Badge -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                                    <Border Background="#FFFF4444" CornerRadius="6" Padding="12,6">
                                                        <TextBlock Text="🚨 CRITICAL" Foreground="#FFFFFFFF" 
                                                                  FontSize="11" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- More Info Link -->
                            <Border Background="{DynamicResource CardBg2}" CornerRadius="10" Padding="20" Margin="0,10,0,0"
                                   BorderThickness="1" BorderBrush="{DynamicResource AccentClr}">
                                <StackPanel>
                                    <TextBlock Text="ℹ️ Learn More" Foreground="{DynamicResource TextPrimary}" FontSize="12" 
                                              FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="11" 
                                              Margin="0,0,0,12">
                                        <Run Text="Visit "/>
                                        <Hyperlink Foreground="{DynamicResource AccentClr}" Command="{Binding OpenBreachGuideCommand}"
                                                  TextDecorations="">Have I Been Pwned</Hyperlink>
                                        <Run Text=" for more information about breaches and how to protect yourself."/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Initial Info (when no check has been done) -->
                        <Border Background="{DynamicResource CardBg2}" CornerRadius="12" Padding="25"
                               Visibility="{Binding LastCheckedEmail, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                            <StackPanel>
                                <TextBlock Text="How It Works" FontSize="14" FontWeight="SemiBold" 
                                          Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
                                <TextBlock Text="• Enter your email address to check against the Have I Been Pwned database" 
                                          Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Text="• We'll securely check if your email appears in breaches (your email is NOT stored)" 
                                          Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Text="• View detailed information about any breaches found" 
                                          Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Text="• Take action to secure your accounts with the provided guidance" 
                                          Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

