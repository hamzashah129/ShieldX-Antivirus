<Window x:Class="ShieldX.Views.UsbScanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShieldX — USB Drive Detected"
        Width="480" Height="280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False">

    <Border CornerRadius="14" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="30" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <!-- Background -->
            <Border Background="#161B27" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="14"/>

            <!-- Accent top -->
            <Border Height="4" VerticalAlignment="Top" CornerRadius="14,14,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00E5CC" Offset="0"/>
                        <GradientStop Color="#7C3AED" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Content -->
            <StackPanel Margin="30,30,30,20" VerticalAlignment="Stretch">
                <!-- Icon + Title -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Width="50" Height="50" CornerRadius="12" Margin="0,0,16,0"
                            VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00E5CC" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🔌" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="USB Drive Detected" FontSize="18" FontWeight="Bold"
                                   Foreground="#FFFFFF" Margin="0,0,0,4"/>
                        <TextBlock x:Name="DriveNameText" Text="E: Drive" FontSize="12"
                                   Foreground="#718096"/>
                    </StackPanel>
                </StackPanel>

                <!-- Message -->
                <TextBlock Text="ShieldX can scan this drive for threats and malware. This helps protect your system from USB-based infections."
                           FontSize="13" Foreground="#CBD5E0" TextWrapping="Wrap"
                           LineHeight="20" Margin="0,0,0,24"/>

                <!-- Details -->
                <Border Background="#12161F" CornerRadius="8" Padding="12" Margin="0,0,0,24"
                        BorderBrush="#1E293B" BorderThickness="1">
                    <TextBlock Text="✓ Scan will run in the background&#10;✓ Threats will be automatically quarantined&#10;✓ You'll receive a notification when complete"
                               FontSize="12" Foreground="#A0AEC0" LineHeight="18"/>
                </Border>

                <!-- Buttons -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="NoButton" Grid.Column="0" Content="Skip Scan"
                            Background="#2D3748" Foreground="#E2E8F0" Margin="0,0,10,0"
                            FontSize="13" FontWeight="SemiBold" Height="40"
                            BorderThickness="0" Cursor="Hand"
                            Click="NoButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="YesButton" Grid.Column="1" Content="🔍 Scan Drive"
                            FontSize="13" FontWeight="Bold" Height="40"
                            BorderThickness="0" Cursor="Hand"
                            Foreground="#000000" Click="YesButton_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00E5CC" Offset="0"/>
                                <GradientStop Color="#00C4AD" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
