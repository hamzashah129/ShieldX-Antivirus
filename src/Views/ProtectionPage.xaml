<Page x:Class="ShieldX.Views.ProtectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ShieldX.Views"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="950"
      Title="Protection"
      Background="{DynamicResource AppBg}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <TextBlock Text="Protection Modules" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

            <ItemsControl x:Name="ModulesControl" ItemsSource="{Binding Modules}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource GlassCard}" Margin="0,0,0,10" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="#1E3A5F" Width="50" Height="50" CornerRadius="10" Padding="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}" FontSize="28" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondary}" Margin="0,5,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="2" IsChecked="{Binding IsActive}" Style="{StaticResource ModernToggle}" Width="50" Height="26" Tag="{Binding Name}" Click="ModuleToggle_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>