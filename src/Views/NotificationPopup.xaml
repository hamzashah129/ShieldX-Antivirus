<Window x:Class="ShieldX.Views.NotificationPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="380" Height="110"
        ResizeMode="NoResize">

    <Window.Resources>
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation
                Storyboard.TargetName="MainBorder"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                From="400" To="0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="MainBorder"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1"
                Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="SlideOut">
            <DoubleAnimation
                Storyboard.TargetName="MainBorder"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                From="0" To="400"
                Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="MainBorder"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0"
                Duration="0:0:0.25"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="MainBorder"
            CornerRadius="14"
            Padding="0"
            ClipToBounds="True"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TranslateTransform X="400"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              Opacity="0.5"
                              BlurRadius="20"
                              ShadowDepth="4"/>
        </Border.Effect>

        <Grid>
            <!-- Background -->
            <Border x:Name="BackgroundBorder" CornerRadius="14" 
                    BorderThickness="1"/>

            <!-- Colored left accent bar -->
            <Border x:Name="AccentBar"
                    Width="5" CornerRadius="14,0,0,14"
                    HorizontalAlignment="Left">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">
                        <GradientStop x:Name="GradTop"
                                      Color="#00E5CC" Offset="0"/>
                        <GradientStop x:Name="GradBottom"
                                      Color="#7C3AED" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Top progress bar (auto-dismiss timer) -->
            <Border CornerRadius="14,14,0,0" Height="3"
                    VerticalAlignment="Top">
                <ProgressBar x:Name="TimerBar"
                             Value="100" Maximum="100"
                             Height="3" Background="Transparent"
                             BorderThickness="0">
                    <ProgressBar.Foreground>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">
                            <GradientStop Color="#00E5CC" Offset="0"/>
                            <GradientStop Color="#7C3AED" Offset="1"/>
                        </LinearGradientBrush>
                    </ProgressBar.Foreground>
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid>
                                <Rectangle x:Name="PART_Track" Fill="Transparent"/>
                                <Rectangle x:Name="PART_Indicator"
                                           HorizontalAlignment="Left">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0"
                                                             EndPoint="1,0">
                                            <GradientStop Color="#00E5CC"
                                                          Offset="0"/>
                                            <GradientStop Color="#7C3AED"
                                                          Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
            </Border>

            <!-- Content -->
            <Grid Margin="18,8,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <Border Grid.Column="0"
                        Width="42" Height="42"
                        CornerRadius="10"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                            <GradientStop x:Name="IconGrad1"
                                          Color="#002E29" Offset="0"/>
                            <GradientStop x:Name="IconGrad2"
                                          Color="#001A2E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock x:Name="IconText"
                               Text="🛡"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Text -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,2">
                        <TextBlock x:Name="ShieldXText" Text="ShieldX"
                                   FontSize="11"
                                   Margin="0,0,8,0"/>
                        <Border x:Name="BadgeBorder"
                                CornerRadius="3" Padding="5,1">
                            <TextBlock x:Name="BadgeText"
                                       Text="PROTECTED"
                                       FontSize="9"
                                       FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="TitleText"
                               Text="No Threats Found"
                               FontSize="14"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="MessageText"
                               Text="Your system is clean and protected"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Close button -->
                <Button Grid.Column="2"
                        x:Name="CloseBtn"
                        Content="✕"
                        Width="24" Height="24"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="11"
                        Click="CloseBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>

