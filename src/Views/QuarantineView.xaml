<UserControl x:Class="ShieldX.Views.QuarantineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{DynamicResource AppBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBg}"
                Margin="24,20,24,0" CornerRadius="12"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="🔒 Quarantine Vault"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="13"
                               Margin="0,4,0,0"
                               Text="Dangerous files safely isolated from your system"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Content="🔄 Refresh"
                            Command="{Binding RefreshCommand}"
                            Padding="14,8" Margin="0,0,8,0"
                            Background="#00E5CC"
                            Foreground="#0D1117"
                            FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="🗑 Delete All"
                            Command="{Binding DeleteAllCommand}"
                            Padding="14,8"
                            Background="#1A0D0D"
                            Foreground="#EF4444"
                            BorderThickness="1"
                            BorderBrush="#EF4444"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stats -->
        <Border Grid.Row="1" Margin="24,12,24,0"
                Background="{DynamicResource CardBg}" CornerRadius="12"
                Padding="20,16">
            <UniformGrid Columns="3">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TotalItems}"
                               Foreground="#EF4444"
                               FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Items Quarantined"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TotalSize}"
                               Foreground="#F59E0B"
                               FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Total Size"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Isolated"
                               Foreground="#10B981"
                               FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Current Status"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- Items grid -->
        <Border Grid.Row="2" Margin="24,12,24,0"
                Background="{DynamicResource CardBg}" CornerRadius="12"
                Padding="20">
            <Grid>
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasNoItems,
                                Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="🔒" FontSize="48"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Quarantine vault is empty"
                               Foreground="{DynamicResource TextPrimary}" FontSize="18"
                               FontWeight="Bold" Margin="0,12,0,4"
                               HorizontalAlignment="Center"/>
                    <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="13"
                               HorizontalAlignment="Center"
                               Text="No threats have been quarantined yet. Run a scan to detect threats."/>
                    <Button Content="🔍 Run Quick Scan"
                            Margin="0,16,0,0"
                            Padding="20,10"
                            Background="#00E5CC"
                            Foreground="#0D1117"
                            FontWeight="Bold"
                            BorderThickness="0"
                            HorizontalAlignment="Center"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          RowBackground="{DynamicResource AppBg}"
                          AlternatingRowBackground="{DynamicResource AltRowBg}"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#1E293B"
                          Visibility="{Binding HasItems,
                              Converter={StaticResource BoolToVis}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File Name"
                            Binding="{Binding FileName}" Width="160"/>
                        <DataGridTextColumn Header="Threat"
                            Binding="{Binding ThreatName}" Width="180"/>
                        <DataGridTemplateColumn Header="Severity"
                                                Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4"
                                            Padding="8,3" Margin="4,3"
                                            Background="#1A0D0D"
                                            HorizontalAlignment="Left">
                                        <TextBlock
                                            Text="{Binding Severity}"
                                            Foreground="#EF4444"
                                            FontSize="11"
                                            FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Size"
                            Binding="{Binding SizeText}" Width="80"/>
                        <DataGridTextColumn Header="Date Isolated"
                            Binding="{Binding DateText}" Width="150"/>
                        <DataGridTextColumn Header="Original Path"
                            Binding="{Binding OriginalPath}" Width="*"/>
                        <DataGridTemplateColumn Header="Actions"
                                                Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="4,2">
                                        <Button Content="↩ Restore"
                                                Width="80" Height="26"
                                                Margin="0,0,4,0"
                                                Background="{DynamicResource HoverBg}"
                                                Foreground="#F59E0B"
                                                FontSize="11"
                                                BorderThickness="1"
                                                BorderBrush="#F59E0B"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.RestoreSelectedCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4"
                                                            Padding="4,2">
                                                        <ContentPresenter
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Content="🗑 Delete"
                                                Width="76" Height="26"
                                                Background="#1A0D0D"
                                                Foreground="#EF4444"
                                                FontSize="11"
                                                BorderThickness="1"
                                                BorderBrush="#EF4444"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.DeleteSelectedCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4"
                                                            Padding="4,2">
                                                        <ContentPresenter
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Margin="24,8,24,16"
                Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="16,8">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
