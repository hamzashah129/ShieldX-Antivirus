<Window x:Class="ShieldX.Views.ExitConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460" Height="240"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border CornerRadius="14" Background="{DynamicResource CardBg}"
            BorderBrush="{DynamicResource BorderClr}" BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.7"
                              BlurRadius="30" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Gradient top accent -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,0">
                        <GradientStop Color="#00E5CC" Offset="0"/>
                        <GradientStop Color="#7C3AED" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="28,20,28,8">
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <Border Width="40" Height="40"
                            CornerRadius="10" Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,1">
                                <GradientStop Color="#00E5CC"
                                              Offset="0"/>
                                <GradientStop Color="#7C3AED"
                                              Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🛡" FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ShieldX Professional"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="15" FontWeight="Bold"/>
                        <TextBlock Text="What would you like to do?"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondary}" FontSize="13"
                           LineHeight="20"
                           Text="Minimize to system tray to keep real-time protection running, or exit ShieldX completely."/>
            </StackPanel>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="{DynamicResource AppBg}"
                    CornerRadius="0,0,14,14" Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            x:Name="CancelBtn"
                            Content="Cancel"
                            Width="80" Height="34"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondary}"
                            BorderBrush="{DynamicResource BorderClr}"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="Cancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2"
                            x:Name="ExitBtn"
                            Content="Exit"
                            Width="80" Height="34"
                            Margin="0,0,8,0"
                            Background="#1A0D0D"
                            Foreground="#EF4444"
                            BorderBrush="#EF4444"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="Exit_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="3"
                            x:Name="TrayBtn"
                            Content="🛡  Minimize to Tray"
                            Height="34"
                            Padding="14,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="Bold"
                            Foreground="#0D1117"
                            Click="Tray_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="#00E5CC"
                                              Offset="0"/>
                                <GradientStop Color="#00C4AD"
                                              Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

