<UserControl x:Class="ShieldX.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0D1117">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="#0D1117">
        <StackPanel Margin="24,24,24,40">

            <!-- ═══════════════════════════════════════════
                 SECTION 1: HERO HEADER CARD
            ═══════════════════════════════════════════ -->
            <Border CornerRadius="10"
                    Margin="0,0,0,14"
                    BorderBrush="#00E5CC"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D1117" Offset="0.0"/>
                        <GradientStop Color="#0D2626" Offset="0.55"/>
                        <GradientStop Color="#004040" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid Margin="28,22,28,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- App Icon Container -->
                    <Border Grid.Column="0"
                            Width="72" Height="72"
                            CornerRadius="14"
                            Background="#0A1F1F"
                            BorderBrush="#00E5CC"
                            BorderThickness="1.5"
                            Margin="0,0,22,0"
                            VerticalAlignment="Center">
                        <Image Source="assets/shieldx.ico"
                               Width="44" Height="44"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <!-- App Title -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="ShieldX Professional Antivirus"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   Foreground="#FFFFFF"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Military-grade protection. Zero compromises."
                                   FontSize="13"
                                   FontFamily="Segoe UI"
                                   Foreground="#A0AEC0"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#0A2020"
                                    BorderBrush="#00E5CC"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="12,5">
                                <TextBlock Text="v 3.1.1"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           FontFamily="Segoe UI"
                                           Foreground="#00E5CC"/>
                            </Border>
                            <Border Background="#0A200A"
                                    BorderBrush="#2EA04D"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="12,5"
                                    Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7"
                                             Fill="#2EA04D"
                                             VerticalAlignment="Center"
                                             Margin="0,0,7,0"/>
                                    <TextBlock Text="Protected"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               FontFamily="Segoe UI"
                                               Foreground="#2EA04D"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>


            <!-- ═══════════════════════════════════════════
                 SECTION 3: DEVELOPER CARD
            ═══════════════════════════════════════════ -->
            <Border Background="#161B22"
                    CornerRadius="10"
                    Margin="0,0,0,14"
                    BorderBrush="#21262D"
                    BorderThickness="1">
                <StackPanel>
                    <!-- Section Header -->
                    <Border Background="#0F1520"
                            CornerRadius="10,10,0,0"
                            Padding="20,13">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="3" Background="#00E5CC" CornerRadius="2"/>
                            <TextBlock Text="DEVELOPER"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       Foreground="#00E5CC"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Rectangle Height="1" Fill="#21262D"/>

                    <!-- Body -->
                    <Grid Margin="22,20,22,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar: Ellipse + initials overlay using Grid -->
                        <Grid Grid.Column="0"
                              Width="72" Height="72"
                              Margin="0,0,20,0"
                              VerticalAlignment="Top">
                            <Ellipse Fill="#0A2020"/>
                            <Ellipse Stroke="#00E5CC" StrokeThickness="2"/>
                            <TextBlock Text="SH"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       Foreground="#00E5CC"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Developer Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Top">
                            <TextBlock Text="SYED HAMZA ALI SHAH"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       Foreground="#00E5CC"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Cybersecurity Developer &amp; Software Engineer"
                                       FontSize="13"
                                       FontFamily="Segoe UI"
                                       FontStyle="Italic"
                                       Foreground="#A0AEC0"
                                       Margin="0,0,0,10"/>

                            <Rectangle Height="1" Fill="#21262D" Margin="0,0,0,10"/>

                            <TextBlock Text="Passionate about building next-generation cybersecurity tools to protect users worldwide."
                                       FontSize="12"
                                       FontFamily="Segoe UI"
                                       Foreground="#8B949E"
                                       TextWrapping="Wrap"
                                       LineHeight="20"
                                       Margin="0,0,0,16"/>

                            <!-- Social Buttons -->
                            <WrapPanel>
                                <Border BorderBrush="#00E5CC"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="14,7"
                                        Margin="0,0,10,0"
                                        Cursor="Hand"
                                        Background="Transparent">
                                    <TextBlock Text="⌥  GitHub"
                                               FontSize="12"
                                               FontFamily="Segoe UI"
                                               Foreground="#00E5CC"/>
                                </Border>
                                <Border BorderBrush="#00E5CC"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="14,7"
                                        Margin="0,0,10,0"
                                        Cursor="Hand"
                                        Background="Transparent">
                                    <TextBlock Text="in  LinkedIn"
                                               FontSize="12"
                                               FontFamily="Segoe UI"
                                               Foreground="#00E5CC"/>
                                </Border>
                                <Border BorderBrush="#00E5CC"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="14,7"
                                        Cursor="Hand"
                                        Background="Transparent">
                                    <TextBlock Text="✉  Email"
                                               FontSize="12"
                                               FontFamily="Segoe UI"
                                               Foreground="#00E5CC"/>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════
                 SECTION 4: SOFTWARE INFO CARD
            ═══════════════════════════════════════════ -->
            <Border Background="#161B22"
                    CornerRadius="10"
                    Margin="0,0,0,14"
                    BorderBrush="#21262D"
                    BorderThickness="1">
                <StackPanel>
                    <!-- Section Header -->
                    <Border Background="#0F1520"
                            CornerRadius="10,10,0,0"
                            Padding="20,13">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="3" Background="#00E5CC" CornerRadius="2"/>
                            <TextBlock Text="SOFTWARE INFO"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       Foreground="#00E5CC"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Rectangle Height="1" Fill="#21262D"/>

                    <!-- Key-Value Table — single Grid keeps columns aligned -->
                    <Grid Margin="22,18,22,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row: Name -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Name"
                                   FontSize="12" FontFamily="Segoe UI"
                                   Foreground="#8B949E"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,14"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="ShieldX Professional Antivirus"
                                   FontSize="12" FontFamily="Segoe UI"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <Rectangle Grid.Row="1" Grid.ColumnSpan="2"
                                   Height="1" Fill="#21262D" Margin="0,0,0,14"/>

                        <!-- Row: Version -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Version"
                                   FontSize="12" FontFamily="Segoe UI"
                                   Foreground="#8B949E"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,14"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="3.1.1"
                                   FontSize="12" FontFamily="Segoe UI"
                                   FontWeight="SemiBold"
                                   Foreground="#00E5CC"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <Rectangle Grid.Row="3" Grid.ColumnSpan="2"
                                   Height="1" Fill="#21262D" Margin="0,0,0,14"/>

                        <!-- Row: Edition -->
                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="Edition"
                                   FontSize="12" FontFamily="Segoe UI"
                                   Foreground="#8B949E"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,14"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Text="Professional Edition"
                                   FontSize="12" FontFamily="Segoe UI"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <Rectangle Grid.Row="5" Grid.ColumnSpan="2"
                                   Height="1" Fill="#21262D" Margin="0,0,0,14"/>

                        <!-- Row: Platform -->
                        <TextBlock Grid.Row="6" Grid.Column="0"
                                   Text="Platform"
                                   FontSize="12" FontFamily="Segoe UI"
                                   Foreground="#8B949E"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,14"/>
                        <TextBlock Grid.Row="6" Grid.Column="1"
                                   Text="Windows 10/11 (.NET 8 WPF)"
                                   FontSize="12" FontFamily="Segoe UI"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <Rectangle Grid.Row="7" Grid.ColumnSpan="2"
                                   Height="1" Fill="#21262D" Margin="0,0,0,14"/>

                        <!-- Row: License -->
                        <TextBlock Grid.Row="8" Grid.Column="0"
                                   Text="License"
                                   FontSize="12" FontFamily="Segoe UI"
                                   Foreground="#8B949E"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="8" Grid.Column="1"
                                   Text="ShieldX Security Labs — Proprietary"
                                   FontSize="12" FontFamily="Segoe UI"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════
                 SECTION 5: SUPPORT & LICENSING CARD
            ═══════════════════════════════════════════ -->
            <Border Background="#161B22"
                    CornerRadius="10"
                    Margin="0,0,0,0"
                    BorderBrush="#21262D"
                    BorderThickness="1">
                <StackPanel>
                    <!-- Section Header -->
                    <Border Background="#0F1520"
                            CornerRadius="10,10,0,0"
                            Padding="20,13">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="3" Background="#00E5CC" CornerRadius="2"/>
                            <TextBlock Text="SUPPORT &amp; LICENSING"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       Foreground="#00E5CC"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Rectangle Height="1" Fill="#21262D"/>

                    <!-- Body -->
                    <StackPanel Margin="22,18,22,22">
                        <!-- Licensed to row -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Licensed to:"
                                       FontSize="12" FontFamily="Segoe UI"
                                       Foreground="#8B949E"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="ShieldX Security Labs"
                                       FontSize="12" FontFamily="Segoe UI"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Support email row -->
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Support:"
                                       FontSize="12" FontFamily="Segoe UI"
                                       Foreground="#8B949E"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       FontSize="12" FontFamily="Segoe UI"
                                       VerticalAlignment="Center">
                                <Hyperlink NavigateUri="mailto:syedhamzaalishah31324@gmail.com"
                                           Foreground="#00E5CC"
                                           TextDecorations="None">
                                    syedhamzaalishah31324@gmail.com
                                </Hyperlink>
                            </TextBlock>
                        </Grid>

                        <!-- Warning box -->
                        <Border Background="#1A0C00"
                                BorderBrush="#C0502A"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="16,13">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="⚠"
                                               FontSize="14"
                                               Foreground="#FF6B35"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Text="Software is not open source."
                                               FontSize="13"
                                               FontFamily="Segoe UI"
                                               FontWeight="Bold"
                                               Foreground="#FF6B35"/>
                                </StackPanel>
                                <TextBlock Text="•  Unauthorized copying, distribution, or modification is strictly prohibited."
                                           FontSize="11"
                                           FontFamily="Segoe UI"
                                           Foreground="#A05030"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="•  This product is licensed for use by authorized ShieldX personnel only."
                                           FontSize="11"
                                           FontFamily="Segoe UI"
                                           Foreground="#A05030"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
