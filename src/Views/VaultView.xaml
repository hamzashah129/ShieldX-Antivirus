<UserControl x:Class="ShieldX.Views.VaultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBg}">
    <Grid>
        <!-- ══ MASTER PASSWORD DIALOG ══ -->
        <Grid Visibility="{Binding ShowMasterPasswordDialog,
                  Converter={StaticResource BoolToVis}}"
              Background="{DynamicResource AppBg}">
            <Border MaxWidth="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="16"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#000"
                        Opacity="0.5" BlurRadius="30"
                        ShadowDepth="0"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="110"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Gradient header -->
                    <Border Grid.Row="0"
                            CornerRadius="16,16,0,0">
                        <Border.Background>
                            <LinearGradientBrush
                                StartPoint="0,0"
                                EndPoint="1,1">
                                <GradientStop Color="#00E5CC"
                                    Offset="0"/>
                                <GradientStop Color="#7C3AED"
                                    Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="🔐" FontSize="32"
                                HorizontalAlignment="Center"/>
                            <TextBlock Text="ShieldX Vault"
                                FontSize="17" FontWeight="Bold"
                                Foreground="{DynamicResource TextPrimary}"
                                HorizontalAlignment="Center"
                                Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Form -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource CardBg}"
                            CornerRadius="0,0,16,16"
                            Padding="32,24">
                        <StackPanel>
                            <TextBlock
                                Text="{Binding VaultDialogTitle}"
                                FontSize="15" FontWeight="Bold"
                                Foreground="{DynamicResource TextPrimary}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,6"/>
                            <TextBlock
                                Text="{Binding VaultDialogSubtitle}"
                                Foreground="{DynamicResource TextSecondary}"
                                FontSize="12"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Margin="0,0,0,20"/>

                            <!-- Password field -->
                            <TextBlock Text="Master Password"
                                Foreground="{DynamicResource TextSecondary}"
                                FontSize="11" FontWeight="Bold"
                                Margin="0,0,0,6"/>
                            <Border Background="{DynamicResource InputBg}"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderClr}"
                                    BorderThickness="1"
                                    Margin="0,0,0,6">
                                <PasswordBox
                                    x:Name="MasterPasswordBox"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextPrimary}"
                                    BorderThickness="0"
                                    Padding="12,10"
                                    FontSize="14"
                                    PasswordChanged="MasterPasswordBox_PasswordChanged"/>
                            </Border>

                            <!-- Error -->
                            <Border Background="#1A0D0D"
                                    CornerRadius="6"
                                    Padding="10,7"
                                    Margin="0,0,0,14"
                                    Visibility="{Binding HasVaultError,
                                        Converter={StaticResource BoolToVis}}">
                                <TextBlock
                                    Text="{Binding VaultErrorMessage}"
                                    Foreground="#EF4444"
                                    FontSize="12"
                                    TextWrapping="Wrap"/>
                            </Border>

                            <!-- Buttons -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                    Content="Cancel"
                                    Command="{Binding CancelVaultCommand}"
                                    Margin="0,0,5,0" Height="40"
                                    Background="{DynamicResource HoverBg}"
                                    Foreground="{DynamicResource TextSecondary}"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8" Height="40">
                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Grid.Column="1"
                                    Content="{Binding VaultActionButtonText}"
                                    Command="{Binding ConfirmVaultPasswordCommand}"
                                    Margin="5,0,0,0" Height="40"
                                    FontWeight="Bold"
                                    Foreground="#0D1117"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                    <Button.Background>
                                        <LinearGradientBrush
                                            StartPoint="0,0"
                                            EndPoint="1,0">
                                            <GradientStop Color="#00E5CC"
                                                Offset="0"/>
                                            <GradientStop Color="#00C4AD"
                                                Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8" Height="40">
                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Security note -->
                            <TextBlock Margin="0,14,0,0"
                                TextAlignment="Center"
                                Foreground="{DynamicResource TextMuted}"
                                FontSize="10"
                                TextWrapping="Wrap"
                                Text="🔒 AES-256-GCM · PBKDF2 · Stored locally only"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ UNLOCKED VAULT CONTENT ══ -->
        <Grid Visibility="{Binding IsVaultUnlocked,
                  Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource CardBg}"
                    Margin="24,20,24,0" CornerRadius="12"
                    Padding="0" ClipToBounds="True">
                <Grid>
                    <!-- Gradient top strip -->
                    <Border Height="4" VerticalAlignment="Top"
                            CornerRadius="12,12,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="#00E5CC" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid Margin="24,12,24,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Lock icon -->
                        <Border Grid.Column="0"
                                Width="44" Height="44"
                                CornerRadius="10"
                                Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#00E5CC"
                                                  Offset="0"/>
                                    <GradientStop Color="#7C3AED"
                                                  Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🔐" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Password Vault"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,3,0,0">
                                <Border Background="#0D2818"
                                        CornerRadius="4" Padding="6,2"
                                        Margin="0,0,8,0">
                                    <TextBlock Foreground="#10B981"
                                               FontSize="11">
                                        <Run Text="🔓 Unlocked · "/>
                                        <Run Text="{Binding Entries.Count}"/>
                                        <Run Text=" entries"/>
                                    </TextBlock>
                                </Border>
                                <Border Background="#1A0D2E"
                                        CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="AES-256 Encrypted"
                                               Foreground="#7C3AED"
                                               FontSize="11"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal">
                            <Button Content="＋  Add Password"
                                    Command="{Binding AddEntryCommand}"
                                    Padding="14,9" Margin="0,0,8,0"
                                    FontSize="13" FontWeight="Bold"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,0">
                                        <GradientStop Color="#00E5CC"
                                                      Offset="0"/>
                                        <GradientStop Color="#00B8A3"
                                                      Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <Button.Foreground>
                                    <SolidColorBrush Color="#0D1117"/>
                                </Button.Foreground>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="🔒 Lock"
                                    Command="{Binding LockVaultCommand}"
                                    Padding="14,9"
                                    FontSize="13"
                                    Background="{DynamicResource HoverBg}"
                                    Foreground="{DynamicResource TextSecondary}"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Stats row -->
            <Border Grid.Row="1" Margin="24,12,24,0"
                    Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="20,14">
                <UniformGrid Columns="4">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Entries.Count}"
                                   Foreground="#00E5CC"
                                   FontSize="24" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Total Entries"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding WeakPasswordCount}"
                                   Foreground="#F59E0B"
                                   FontSize="24" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Weak Passwords"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding DuplicateCount}"
                                   Foreground="#EF4444"
                                   FontSize="24" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Duplicates"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="AES-256"
                                   Foreground="#10B981"
                                   FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Encryption"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- Password generator -->
            <Border Grid.Row="2" Margin="24,12,24,0"
                    Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="🎲 Password Generator"
                                   Foreground="#00E5CC"
                                   FontSize="12" FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <!-- Generated password display -->
                        <Border Background="{DynamicResource AppBg}"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource BorderClr}"
                                BorderThickness="1"
                                Margin="0,0,0,10">
                            <Grid>
                                <TextBox
                                    Text="{Binding GeneratedPassword}"
                                    Background="Transparent"
                                    Foreground="#00E5CC"
                                    BorderThickness="0"
                                    Padding="12,10"
                                    FontSize="14"
                                    IsReadOnly="True"
                                    FontFamily="Consolas"/>
                            </Grid>
                        </Border>

                        <!-- Options row -->
                        <WrapPanel>
                            <TextBlock Text="Length:"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" FontSize="12"/>
                            <Slider Value="{Binding PasswordLength}"
                                    Minimum="8" Maximum="64"
                                    Width="120"
                                    VerticalAlignment="Center"/>
                            <Border Background="#0D2818"
                                    CornerRadius="4" Padding="8,3"
                                    Margin="6,0,16,0">
                                <TextBlock Text="{Binding PasswordLength}"
                                           Foreground="#00E5CC"
                                           FontSize="12"
                                           FontWeight="Bold"/>
                            </Border>
                            <CheckBox Content="A-Z"
                                      IsChecked="{Binding UseUppercase}"
                                      Foreground="{DynamicResource TextSecondary}"
                                      FontSize="12" Margin="0,0,10,0"/>
                            <CheckBox Content="0-9"
                                      IsChecked="{Binding UseNumbers}"
                                      Foreground="{DynamicResource TextSecondary}"
                                      FontSize="12" Margin="0,0,10,0"/>
                            <CheckBox Content="!@#"
                                      IsChecked="{Binding UseSymbols}"
                                      Foreground="{DynamicResource TextSecondary}"
                                      FontSize="12"/>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                        <Button Content="🎲 Generate"
                                Command="{Binding GeneratePasswordCommand}"
                                Padding="14,9" Margin="0,0,0,6"
                                Background="#7C3AED"
                                Foreground="{DynamicResource TextPrimary}"
                                FontSize="12" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="📋 Copy"
                                Command="{Binding CopyGeneratedCommand}"
                                Padding="14,9"
                                Background="{DynamicResource HoverBg}"
                                Foreground="{DynamicResource TextPrimary}"
                                FontSize="12"
                                BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Entries table -->
            <Border Grid.Row="3" Margin="24,12,24,24"
                    Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource AppBg}"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource BorderClr}"
                                BorderThickness="1"
                                Margin="0,0,8,0">
                            <TextBox
                                Text="{Binding SearchText,
                                    UpdateSourceTrigger=PropertyChanged}"
                                Background="Transparent"
                                Foreground="{DynamicResource TextPrimary}"
                                BorderThickness="0"
                                Padding="12,9" FontSize="13"/>
                        </Border>
                        <TextBlock Grid.Column="0"
                                   Text="🔍  Search passwords..."
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="13"
                                   Padding="14,9"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding IsSearchEmpty,
                                       Converter={StaticResource BoolToVis}}"/>
                        <Border Grid.Column="1"
                                Background="#0D2818"
                                CornerRadius="6" Padding="10,6">
                            <TextBlock Foreground="#10B981" FontSize="11">
                                <Run Text="{Binding FilteredEntries.Count}"/>
                                <Run Text=" entries"/>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasNoEntries,
                                    Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="🔑" FontSize="40"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="No passwords saved yet"
                                   Foreground="{DynamicResource TextPrimary}" FontSize="16"
                                   FontWeight="Bold" Margin="0,12,0,6"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                   HorizontalAlignment="Center"
                                   Text="Click '+ Add Password' to save your first entry"/>
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FilteredEntries}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Background="Transparent"
                              RowBackground="{DynamicResource AppBg}"
                              AlternatingRowBackground="#0F1520"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#1E293B"
                              HeadersVisibility="Column"
                              Visibility="{Binding HasEntries,
                                  Converter={StaticResource BoolToVis}}">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"
                                        Value="#161B27"/>
                                <Setter Property="Foreground"
                                        Value="#718096"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight"
                                        Value="Bold"/>
                                <Setter Property="Padding"
                                        Value="12,8"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <!-- Site with favicon placeholder -->
                            <DataGridTemplateColumn Header="WEBSITE / APP"
                                                    Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="8,6">
                                            <Border Width="28" Height="28"
                                                    CornerRadius="6"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0"
                                                                         EndPoint="1,1">
                                                        <GradientStop Color="#1E293B"
                                                                      Offset="0"/>
                                                        <GradientStop Color="#2D3748"
                                                                      Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock
                                                    Text="{Binding SiteInitial}"
                                                    Foreground="#00E5CC"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Site}"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontSize="13"
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Category}"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           FontSize="10"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Username -->
                            <DataGridTextColumn Header="USERNAME / EMAIL"
                                Binding="{Binding Username}"
                                Width="180"/>

                            <!-- Password masked -->
                            <DataGridTemplateColumn Header="PASSWORD"
                                                    Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="8,0">
                                            <TextBlock
                                                Text="{Binding DisplayPassword}"
                                                Foreground="{DynamicResource TextSecondary}"
                                                FontFamily="Consolas"
                                                FontSize="13"
                                                VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Strength badge -->
                            <DataGridTemplateColumn Header="STRENGTH"
                                                    Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4"
                                                Padding="8,3"
                                                Margin="8,4"
                                                HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"
                                                            Value="#0D2818"/>
                                                    <Style.Triggers>
                                                        <DataTrigger
                                                            Binding="{Binding Strength}"
                                                            Value="Weak">
                                                            <Setter Property="Background"
                                                                    Value="#1A0D0D"/>
                                                        </DataTrigger>
                                                        <DataTrigger
                                                            Binding="{Binding Strength}"
                                                            Value="Medium">
                                                            <Setter Property="Background"
                                                                    Value="#1A150D"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock
                                                Text="{Binding Strength}"
                                                FontSize="11"
                                                FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground"
                                                                Value="#10B981"/>
                                                        <Style.Triggers>
                                                            <DataTrigger
                                                                Binding="{Binding Strength}"
                                                                Value="Weak">
                                                                <Setter Property="Foreground"
                                                                        Value="#EF4444"/>
                                                            </DataTrigger>
                                                            <DataTrigger
                                                                Binding="{Binding Strength}"
                                                                Value="Medium">
                                                                <Setter Property="Foreground"
                                                                        Value="#F59E0B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Actions -->
                            <DataGridTemplateColumn Header="ACTIONS"
                                                    Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel
                                            Orientation="Horizontal"
                                            Margin="4,3">
                                            <Button Content="📋"
                                                    ToolTip="Copy password"
                                                    Width="32" Height="28"
                                                    Margin="0,0,4,0"
                                                    Background="#0D2818"
                                                    Foreground="#00E5CC"
                                                    FontSize="13"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.CopyPasswordCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="6"
                                                                Padding="4,2">
                                                            <ContentPresenter
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="👁"
                                                    ToolTip="Show/hide password"
                                                    Width="32" Height="28"
                                                    Margin="0,0,4,0"
                                                    Background="#1A150D"
                                                    Foreground="#F59E0B"
                                                    FontSize="13"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.ToggleShowPasswordCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="6"
                                                                Padding="4,2">
                                                            <ContentPresenter
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="✏"
                                                    ToolTip="Edit"
                                                    Width="32" Height="28"
                                                    Margin="0,0,4,0"
                                                    Background="#1A1A2E"
                                                    Foreground="#7C3AED"
                                                    FontSize="13"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.EditEntryCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="6"
                                                                Padding="4,2">
                                                            <ContentPresenter
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="🗑"
                                                    ToolTip="Delete"
                                                    Width="32" Height="28"
                                                    Background="#1A0D0D"
                                                    Foreground="#EF4444"
                                                    FontSize="13"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.DeleteEntryCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="6"
                                                                Padding="4,2">
                                                            <ContentPresenter
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
