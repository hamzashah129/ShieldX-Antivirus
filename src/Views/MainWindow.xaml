<Window x:Class="ShieldX.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShieldX.Views"
        mc:Ignorable="d"
        Title="ShieldX Professional Antivirus v3.2.0" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        Icon="pack://application:,,,/assets/shieldx.ico"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Window.InputBindings>
        <!-- Keyboard Shortcuts -->
        <KeyBinding Key="Q" Modifiers="Ctrl" Command="{x:Static local:MainWindow.QuickScanCommand}" />
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{x:Static local:MainWindow.FullScanCommand}" />
        <KeyBinding Key="L" Modifiers="Ctrl" Command="{x:Static local:MainWindow.LogsCommand}" />
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{x:Static local:MainWindow.NetworkCommand}" />
        <KeyBinding Key="OemComma" Modifiers="Ctrl" Command="{x:Static local:MainWindow.SettingsCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <!-- Page Transition Animations -->
        <Storyboard x:Key="PageTransitionIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
        </Storyboard>
        <Storyboard x:Key="PageTransitionOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.2"/>
        </Storyboard>

        <!-- Sidebar Collapse Animation -->
        <Storyboard x:Key="SidebarCollapse">
            <DoubleAnimation Storyboard.TargetProperty="Width" From="250" To="48" Duration="0:0:0.3"/>
        </Storyboard>

        <!-- Sidebar Expand Animation -->
        <Storyboard x:Key="SidebarExpand">
            <DoubleAnimation Storyboard.TargetProperty="Width" From="48" To="250" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>

    <Border Background="{DynamicResource AppBg}" BorderBrush="#FF1E3A5F" BorderThickness="1" CornerRadius="10">
        <Grid>
            <!-- Custom Title Bar -->
            <Border Height="40" VerticalAlignment="Top" Background="{DynamicResource AppBg}" BorderBrush="#FF1E3A5F" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title and Icon -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                        <Path Data="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z" Fill="#FF00D4AA" Width="20" Height="20" Margin="0,0,10,0"/>
                        <TextBlock Text="ShieldX Professional Antivirus" FontSize="14" FontWeight="Bold" Foreground="#FF8899AA"/>
                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Button x:Name="ThemeToggleButton" Content="🌙" FontSize="14" Width="40" Height="30" 
                                Background="Transparent" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                                Click="ThemeToggleButton_Click" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave"
                                ToolTip="Toggle Light/Dark Mode"/>
                        <Button x:Name="MinimizeButton" Content="─" FontSize="14" Width="40" Height="30" Background="Transparent" Foreground="#FF8899AA" BorderThickness="0"
                                Click="MinimizeButton_Click" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave"/>
                        <Button x:Name="MaximizeButton" Content="□" FontSize="12" Width="40" Height="30" Background="Transparent" Foreground="#FF8899AA" BorderThickness="0"
                                Click="MaximizeButton_Click" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave"/>
                        <Button x:Name="CloseButton" Content="✕" FontSize="14" Width="40" Height="30" Background="Transparent" Foreground="#FF8899AA" BorderThickness="0"
                                Click="CloseButton_Click" MouseEnter="CloseButton_MouseEnter" MouseLeave="CloseButton_MouseLeave"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Margin="0,40,0,0">
                <!-- Sidebar -->
                <Border x:Name="SidebarBorder" Background="{DynamicResource CardBg}" Width="250" HorizontalAlignment="Left">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Logo Section -->
                            <RowDefinition Height="*"/>     <!-- Navigation (scrollable) -->
                            <RowDefinition Height="Auto"/>  <!-- System Status -->
                        </Grid.RowDefinitions>

                        <!-- Logo Section -->
                        <Border Grid.Row="0" Height="90" Background="{DynamicResource AccentClr}" CornerRadius="0,0,15,15" Padding="0">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🛡️" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="ShieldX" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF" 
                                             HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="Professional" FontSize="10" Foreground="#FFFFFF" Opacity="0.9"
                                             HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- Collapse Toggle in Logo Area -->
                                <Button x:Name="SidebarToggleButton" HorizontalAlignment="Left" VerticalAlignment="Top" 
                                       Content="◄" Height="36" Width="36" Margin="8,8,0,0"
                                       Background="Transparent" Foreground="#FFFFFF" BorderThickness="0" FontSize="12"
                                       Click="SidebarToggleButton_Click" ToolTip="Collapse/Expand Sidebar" Opacity="0.8"/>
                            </Grid>
                        </Border>

                        <!-- Navigation Menu (Scrollable with sections) -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" 
                                     PanningMode="VerticalOnly" Margin="0,10,0,10">
                            <StackPanel>
                                <!-- Main Navigation Section -->
                                <TextBlock Text="MAIN" FontSize="10" Foreground="{DynamicResource TextPrimary}" 
                                         FontWeight="Bold" Margin="15,5,15,12" Opacity="0.9"/>
                                
                                <ListBox x:Name="NavigationListBox" Background="Transparent" BorderThickness="0"
                                        Margin="8,0,8,8" SelectionChanged="NavigationListBox_SelectionChanged">
                                    <ListBox.Resources>
                                        <!-- Enhanced Navigation Item Styling -->
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="NavItemBorder" Padding="14,12" CornerRadius="10" Margin="0,3" 
                                                               Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                                               Cursor="Hand">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                
                                                                <TextBlock x:Name="NavIcon" Text="{Binding Icon}" FontSize="18" 
                                                                          VerticalAlignment="Center" Margin="0,0,12,0" Opacity="1" Foreground="{DynamicResource TextPrimary}"/>
                                                                <TextBlock x:Name="NavItemName" Grid.Column="1" Text="{Binding Name}" 
                                                                          FontSize="13" Foreground="{DynamicResource TextPrimary}" 
                                                                          VerticalAlignment="Center" FontWeight="Medium" Opacity="1"/>
                                                            </Grid>
                                                        </Border>
                                                        
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="NavItemBorder" Property="Background" Value="{DynamicResource HoverBg}"/>
                                                                <Setter TargetName="NavIcon" Property="Opacity" Value="1"/>
                                                                <Setter TargetName="NavItemName" Property="Foreground" Value="{DynamicResource AccentClr}"/>
                                                                <Setter TargetName="NavItemName" Property="Opacity" Value="1"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="NavItemBorder" Property="Background" Value="{DynamicResource NavSelectedBg}"/>
                                                                <Setter TargetName="NavItemBorder" Property="BorderBrush" Value="{DynamicResource AccentClr}"/>
                                                                <Setter TargetName="NavItemBorder" Property="BorderThickness" Value="2,0,0,0"/>
                                                                <Setter TargetName="NavItemBorder" Property="Padding" Value="12,12,14,12"/>
                                                                <Setter TargetName="NavIcon" Property="Opacity" Value="1"/>
                                                                <Setter TargetName="NavItemName" Property="Foreground" Value="{DynamicResource AccentClr}"/>
                                                                <Setter TargetName="NavItemName" Property="FontWeight" Value="SemiBold"/>
                                                                <Setter TargetName="NavItemName" Property="Opacity" Value="1"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.Resources>
                                </ListBox>

                                <!-- Tools Section -->
                                <TextBlock Text="TOOLS" FontSize="10" Foreground="{DynamicResource TextPrimary}" 
                                         FontWeight="Bold" Margin="15,15,15,12" Opacity="0.9"/>
                                
                                <ListBox x:Name="ToolsListBox" Background="Transparent" BorderThickness="0"
                                        Margin="8,0,8,20" SelectionChanged="NavigationListBox_SelectionChanged">
                                    <ListBox.Resources>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="NavItemBorder" Padding="14,12" CornerRadius="10" Margin="0,3" 
                                                               Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                                               Cursor="Hand">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                
                                                                <TextBlock x:Name="NavIcon" Text="{Binding Icon}" FontSize="18" 
                                                                          VerticalAlignment="Center" Margin="0,0,12,0" Opacity="1" Foreground="{DynamicResource TextPrimary}"/>
                                                                <TextBlock x:Name="NavItemName" Grid.Column="1" Text="{Binding Name}" 
                                                                          FontSize="13" Foreground="{DynamicResource TextPrimary}" 
                                                                          VerticalAlignment="Center" FontWeight="Medium" Opacity="1"/>
                                                            </Grid>
                                                        </Border>
                                                        
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="NavItemBorder" Property="Background" Value="{DynamicResource HoverBg}"/>
                                                                <Setter TargetName="NavIcon" Property="Opacity" Value="1"/>
                                                                <Setter TargetName="NavItemName" Property="Foreground" Value="{DynamicResource AccentClr}"/>
                                                                <Setter TargetName="NavItemName" Property="Opacity" Value="1"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="NavItemBorder" Property="Background" Value="#1A4D48"/>
                                                                <Setter TargetName="NavItemBorder" Property="BorderBrush" Value="{DynamicResource AccentClr}"/>
                                                                <Setter TargetName="NavItemBorder" Property="BorderThickness" Value="2,0,0,0"/>
                                                                <Setter TargetName="NavItemBorder" Property="Padding" Value="12,12,14,12"/>
                                                                <Setter TargetName="NavIcon" Property="Opacity" Value="1"/>
                                                                <Setter TargetName="NavItemName" Property="Foreground" Value="{DynamicResource AccentClr}"/>
                                                                <Setter TargetName="NavItemName" Property="FontWeight" Value="SemiBold"/>
                                                                <Setter TargetName="NavItemName" Property="Opacity" Value="1"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.Resources>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Separator -->
                        <Border Grid.Row="2" Height="1" Background="#2D3748" Margin="15,0"/>

                        <!-- System Status -->
                        <Border Grid.Row="2" Margin="12,10,12,12" Padding="12,14" CornerRadius="12" Background="{DynamicResource CardBg2}">
                            <StackPanel>
                                <TextBlock Text="System Status" FontSize="11" FontWeight="SemiBold" 
                                         Foreground="{DynamicResource TextSecondary}" Opacity="0.85" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#2ED573" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SystemStatusText" Grid.Column="1" Text="Protected" FontSize="13" FontWeight="SemiBold"
                                             Foreground="{StaticResource AccentSuccessBrush}"/>
                                </Grid>
                                <TextBlock Text="Security Level" FontSize="10" Foreground="{DynamicResource TextSecondary}" Opacity="0.8" Margin="0,0,0,4"/>
                                <ProgressBar x:Name="SystemHealthBar" Height="5" Value="95" Margin="0,0,0,10"
                                           Foreground="#00E5CC" Background="#1A2D3F"/>
                                <TextBlock x:Name="LastScanTimeText" Text="Last scan: Today, 2:45 PM" FontSize="10"
                                         Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Opacity="0.8"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Main Content Area -->
                <Border x:Name="MainContentArea" Margin="250,0,0,0" Background="{DynamicResource AppBg}">
                    <Grid>
                        <!-- Enhanced Header -->
                        <Border Height="65" VerticalAlignment="Top" Background="{DynamicResource CardBg}" CornerRadius="0,0,15,0">
                            <Grid Margin="30,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="PageTitleText" Text="Dashboard" FontSize="24" FontWeight="Bold"
                                             Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock x:Name="PageSubtitleText" Text="Real-time system protection overview" FontSize="12"
                                             Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" Opacity="0.8"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="ClockText" Text="12:00 PM" FontSize="13" Foreground="{DynamicResource TextSecondary}" 
                                             VerticalAlignment="Center" FontWeight="Medium" Margin="0,0,12,0"/>
                                    <Button Content="⚙️" Margin="0" Background="Transparent" BorderThickness="0" 
                                           Foreground="{DynamicResource TextSecondary}" FontSize="14" Cursor="Hand"
                                           ToolTip="Settings"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Content Frame -->
                        <Frame x:Name="ContentFrame" Margin="0,65,0,0" NavigationUIVisibility="Hidden"/>
                    </Grid>
                </Border>

                <!-- Loading Overlay -->
                <Border x:Name="LoadingOverlay" Background="#80000000" Visibility="Collapsed">
                    <Border Style="{StaticResource GlassCard}" Width="200" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Loading..." HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                            <ProgressBar IsIndeterminate="True" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
