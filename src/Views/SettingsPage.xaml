<Page x:Class="ShieldX.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ShieldX.Views"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="950"
      Title="Settings"
      Background="{DynamicResource AppBg}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

            <Border Style="{StaticResource GlassCard}" Padding="20" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Protection Modules" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>

                    <ItemsControl ItemsSource="{Binding Modules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" Padding="10" Background="{DynamicResource CardBg}" CornerRadius="5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Icon}" FontSize="20" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                        </StackPanel>
                                        <ToggleButton Grid.Column="2" IsChecked="{Binding IsActive}" Style="{StaticResource ModernToggle}" Width="50" Height="26"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Theme Toggle Section -->
            <Border Style="{StaticResource GlassCard}" Padding="20" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Appearance" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Theme" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding CurrentThemeText}" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,15"/>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="🌙 Dark Mode" Command="{Binding SetDarkThemeCommand}" 
                                Style="{StaticResource AccentButton}" Padding="15,8" FontSize="12" Cursor="Hand" Margin="0,0,10,0"
                                Background="{StaticResource AccentClr}" Foreground="{DynamicResource TextPrimary}"/>
                        <Button Content="☀️ Light Mode" Command="{Binding SetLightThemeCommand}" 
                                Style="{StaticResource SecondaryButton}" Padding="15,8" FontSize="12" Cursor="Hand"
                                Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GlassCard}" Padding="20" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="System Integration" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>

                    <TextBlock Text="Windows Explorer Context Menu" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>
                    <TextBlock Text="Add 'Scan with ShieldX' option to Windows Explorer right-click context menu." FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Status:" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{Binding ContextMenuStatus}" FontSize="12" Foreground="{Binding ContextMenuStatusColor}" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="Register" Command="{Binding RegisterContextMenuCommand}" 
                                    Style="{StaticResource AccentButton}" Padding="15,8" FontSize="12" Cursor="Hand" Margin="0,0,10,0"/>
                            <Button Content="Unregister" Command="{Binding UnregisterContextMenuCommand}" 
                                    Style="{StaticResource SecondaryButton}" Padding="15,8" FontSize="12" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding ContextMenuErrorMessage}" FontSize="12" Foreground="#FF6B4C" Margin="0,15,0,0" TextWrapping="Wrap" 
                               Visibility="{Binding HasContextMenuError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>


        </StackPanel>
    </ScrollViewer>
</Page>