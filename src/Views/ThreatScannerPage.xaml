<Page x:Class="ShieldX.Views.ThreatScannerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:ShieldX.Views"
      Background="{DynamicResource AppBg}">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NonZeroToVisibilityConverter x:Key="NonZeroToVis"/>
    </Page.Resources>

    <ScrollViewer Background="{DynamicResource AppBg}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,30">

            <!-- Header -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" 
                    Padding="24,16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="🔬  Threat Scanner"
                                   FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="13" Margin="0,4,0,0"
                                   Text="Scan URLs, Files, IPs and Hashes with 10+ security engines simultaneously"/>
                    </StackPanel>
                    <!-- Engine count badge -->
                    <Border Grid.Column="1" Background="#0D2818"
                            CornerRadius="8" Padding="14,8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="10+" Foreground="#00E5CC"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Engines" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Input area -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Enter URL, IP address, file hash, or browse a file"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>

                    <!-- Input box -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource AppBg}"
                                CornerRadius="8" Padding="2"
                                BorderBrush="{DynamicResource BorderClr}" BorderThickness="1">
                            <TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                                     BorderThickness="0" Padding="12,10"
                                     FontSize="13" VerticalContentAlignment="Center"
                                     AcceptsReturn="False"/>
                        </Border>
                        <Button Grid.Column="1" Content="✕ Clear"
                                Command="{Binding ClearCommand}"
                                Margin="8,0,0,0" Padding="12,10"
                                Background="{DynamicResource HoverBg}" Foreground="{DynamicResource TextSecondary}"
                                BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Scan buttons -->
                    <UniformGrid Columns="3" Margin="0,0,0,8">
                        <Button Content="🌐  Scan URL"
                                Command="{Binding ScanUrlCommand}"
                                Margin="0,0,6,0" Padding="0,12"
                                Background="#00E5CC" Foreground="#0D1117"
                                FontWeight="Bold" BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="📁  Scan File"
                                Command="{Binding ScanFileCommand}"
                                Margin="3,0" Padding="0,12"
                                Background="#7C3AED" Foreground="{DynamicResource TextPrimary}"
                                FontWeight="Bold" BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="🖧  Scan IP"
                                Command="{Binding ScanIpCommand}"
                                Margin="6,0,0,0" Padding="0,12"
                                Background="#F59E0B" Foreground="{DynamicResource TextPrimary}"
                                FontWeight="Bold" BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </UniformGrid>

                    <!-- Supported engines list -->
                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock Text="Engines: " Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,4,0"/>
                        <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap"
                                   Text="VirusTotal · MalwareBazaar · URLScan.io · Google Safe Browsing · PhishTank · AbuseIPDB · ShieldX Engine · ThreatIntel DB · URL Rules · IP Intel"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Scanning progress -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                    Padding="30" Margin="0,0,0,16"
                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="36"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Scanning with 10+ security engines..."
                               Foreground="{DynamicResource TextPrimary}" FontSize="16"
                               FontWeight="Bold" Margin="0,12,0,4"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12"
                               HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Height="4"
                                 Foreground="#00E5CC" Background="{DynamicResource HoverBg}"
                                 Margin="0,16,0,0" Width="300"/>
                </StackPanel>
            </Border>

            <!-- Results -->
            <StackPanel Visibility="{Binding ShowResult, Converter={StaticResource BoolToVis}}">

                <!-- Overall verdict -->
                <Border CornerRadius="12" Padding="24"
                        Margin="0,0,0,16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#0D2818"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentReport.OverallRating}"
                                             Value="Dangerous">
                                    <Setter Property="Background" Value="#1A0D0D"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentReport.OverallRating}"
                                             Value="Suspicious">
                                    <Setter Property="Background" Value="#1A150D"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Verdict icon -->
                        <TextBlock Grid.Column="0" FontSize="48"
                                   VerticalAlignment="Center" Margin="0,0,20,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="✅"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentReport.OverallRating}"
                                                     Value="Dangerous">
                                            <Setter Property="Text" Value="🚨"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentReport.OverallRating}"
                                                     Value="Suspicious">
                                            <Setter Property="Text" Value="⚠"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Verdict text -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="20" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="✓ Target appears Safe"/>
                                        <Setter Property="Foreground" Value="#10B981"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentReport.OverallRating}"
                                                         Value="Dangerous">
                                                <Setter Property="Text" Value="⚠ DANGEROUS — Threat Detected!"/>
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentReport.OverallRating}"
                                                         Value="Suspicious">
                                                <Setter Property="Text" Value="⚠ Suspicious — Review Carefully"/>
                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding CurrentReport.Target}"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                       Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Stats -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <UniformGrid Columns="3" Margin="0,0,0,8">
                                <StackPanel Margin="8,0" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentReport.MaliciousCount}"
                                               Foreground="#EF4444" FontSize="22"
                                               FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Malicious" Foreground="{DynamicResource TextSecondary}"
                                               FontSize="10" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="8,0" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentReport.SuspiciousCount}"
                                               Foreground="#F59E0B" FontSize="22"
                                               FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Suspicious" Foreground="{DynamicResource TextSecondary}"
                                               FontSize="10" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="8,0" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentReport.CleanCount}"
                                               Foreground="#10B981" FontSize="22"
                                               FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Clean" Foreground="{DynamicResource TextSecondary}"
                                               FontSize="10" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </UniformGrid>
                            <Button Content="📋 Copy Report"
                                    Command="{Binding CopyReportCommand}"
                                    HorizontalAlignment="Right"
                                    Padding="12,6" Background="{DynamicResource HoverBg}"
                                    Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- File details (shown for file scans) -->
                <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                        Padding="20" Margin="0,0,0,16"
                        Visibility="{Binding CurrentReport.Details.Count, Converter={StaticResource NonZeroToVis}}">
                    <StackPanel>
                        <TextBlock Text="📄 File Details" Foreground="{DynamicResource TextPrimary}"
                                   FontWeight="Bold" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding CurrentReport.Details}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Key}"
                                                   Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                   Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Engine results table -->
                <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource TextPrimary}" FontSize="15"
                                   FontWeight="Bold" Margin="0,0,0,12">
                            <Run Text="Engine Results ("/>
                            <Run Text="{Binding CurrentReport.TotalEngines}"/>
                            <Run Text=" engines)"/>
                        </TextBlock>

                        <DataGrid ItemsSource="{Binding EngineResults}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent"
                                  RowBackground="{DynamicResource AppBg}"
                                  AlternatingRowBackground="{DynamicResource AltRowBg}"
                                  Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#1E293B"
                                  MaxHeight="400">
                            <DataGrid.Columns>

                                <!-- Engine name -->
                                <DataGridTextColumn Header="Security Engine"
                                    Binding="{Binding EngineName}" Width="200"/>

                                <!-- Result with color -->
                                <DataGridTemplateColumn Header="Result" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,3"
                                                    HorizontalAlignment="Left" Margin="4,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#0D2818"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Result}"
                                                                         Value="Malicious">
                                                                <Setter Property="Background" Value="#1A0D0D"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Result}"
                                                                         Value="Suspicious">
                                                                <Setter Property="Background" Value="#1A150D"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Result}"
                                                                         Value="Unknown">
                                                                <Setter Property="Background" Value="#1A1A1A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Result}" FontSize="11"
                                                           FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Result}"
                                                                             Value="Malicious">
                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Result}"
                                                                             Value="Suspicious">
                                                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Result}"
                                                                             Value="Unknown">
                                                                    <Setter Property="Foreground" Value="#718096"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Category/details -->
                                <DataGridTextColumn Header="Details"
                                    Binding="{Binding Category}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
