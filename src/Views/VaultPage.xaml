<Page x:Class="ShieldX.Views.VaultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ShieldX.Views"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Password Vault"
      Background="{DynamicResource AppBg}"
      Loaded="Page_Loaded">

    <Grid>
        <!-- ════════════════════════════════════════════════════ -->
        <!-- MASTER PASSWORD DIALOG (Unlock/Create Vault)         -->
        <!-- ════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding ShowMasterPasswordDialog, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#CC000000" Panel.ZIndex="100">
            <Border MaxWidth="480" Padding="0" CornerRadius="16" ClipToBounds="True"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.5" BlurRadius="30" ShadowDepth="0"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="110"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header with Gradient -->
                    <Border Grid.Row="0" CornerRadius="16,16,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00E5CC" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🔐" FontSize="36" HorizontalAlignment="Center"/>
                            <TextBlock Text="ShieldX Vault" FontSize="18" FontWeight="Bold"
                                       Foreground="#0D1117" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Form Content -->
                    <Border Grid.Row="1" Background="{DynamicResource CardBg}" CornerRadius="0,0,16,16" Padding="32,28">
                        <StackPanel>
                            <!-- Title -->
                            <TextBlock Text="{Binding VaultDialogTitle}" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            
                            <!-- Subtitle -->
                            <TextBlock Text="{Binding VaultDialogSubtitle}" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap" Margin="0,0,0,24"/>

                            <!-- Master Password Input -->
                            <TextBlock Text="Master Password" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource InputBg}" CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderClr}" BorderThickness="1" Margin="0,0,0,8">
                                <PasswordBox x:Name="PasswordInput" Background="Transparent"
                                           Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                                           Padding="12,10" FontSize="13" KeyDown="PasswordBox_KeyDown"/>
                            </Border>

                            <!-- Error Message -->
                            <Border Background="#1A0D0D" CornerRadius="6" Padding="12,8" Margin="0,0,0,16"
                                    Visibility="{Binding HasVaultError, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding VaultErrorMessage}" Foreground="#EF4444"
                                          FontSize="12" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Buttons -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelVaultCommand}"
                                       Height="40" Margin="0,0,8,0" BorderThickness="0"
                                       Background="{DynamicResource HoverBg}" Foreground="{DynamicResource TextSecondary}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Grid.Column="1" x:Name="MasterPasswordButton"
                                       Content="{Binding VaultActionButtonText}"
                                       Command="{Binding ConfirmVaultPasswordCommand}"
                                       Height="40" Margin="8,0,0,0" BorderThickness="0"
                                       FontWeight="Bold" Foreground="#0D1117">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00E5CC" Offset="0"/>
                                            <GradientStop Color="#00C4AD" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Security Info -->
                            <TextBlock Text="🔒 AES-256-GCM · PBKDF2 · Local only" Margin="0,16,0,0"
                                      TextAlignment="Center" Foreground="{DynamicResource TextMuted}"
                                      FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════ -->
        <!-- MAIN VAULT CONTENT (When Unlocked)                   -->
        <!-- ════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsVaultUnlocked, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <Border Grid.Row="0" Background="{DynamicResource CardBg}" Margin="24,20,24,0" 
                    CornerRadius="12,12,0,0" Padding="0" ClipToBounds="True">
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Accent Bar -->
                    <Border Grid.Row="0" Height="4" VerticalAlignment="Top" CornerRadius="12,12,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00E5CC" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid Grid.Row="1" Margin="24,16,24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Title -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="🔐 Password Vault" FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Securely manage all your passwords" FontSize="12" Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="➕ Add Password" Command="{Binding AddEntryCommand}"
                               Height="36" Padding="16,0" BorderThickness="0" Margin="0,0,10,0"
                               Foreground="#FFFFFF" FontWeight="SemiBold">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00E5CC" Offset="0"/>
                                    <GradientStop Color="#00C4AD" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="🔓 Lock Vault" Command="{Binding LockVaultCommand}"
                               Height="36" Padding="16,0" BorderThickness="0"
                               Background="{DynamicResource HoverBg}" Foreground="{DynamicResource TextSecondary}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Search Bar & Stats -->
            <Border Grid.Row="1" Background="{DynamicResource CardBg}" Margin="24,0,24,0"
                    BorderBrush="{DynamicResource BorderClr}" BorderThickness="0,1,0,0">
                <Grid Margin="24,16,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Input -->
                    <Border Grid.Column="0" Background="{DynamicResource InputBg}" CornerRadius="8"
                           BorderBrush="{DynamicResource BorderClr}" BorderThickness="1" MaxWidth="350">
                        <Grid>
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="12,0,0,0"
                                      Foreground="{DynamicResource TextMuted}"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                    Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                                    BorderThickness="0" Padding="32,8,12,8" FontSize="12"/>
                        </Grid>
                    </Border>

                    <!-- Stats -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="24,0,0,0"
                               VerticalAlignment="Center">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="{Binding FilteredEntries.Count}" FontSize="16" FontWeight="Bold"
                                      Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Stored" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>

                        <StackPanel Margin="16,0,0,0">
                            <TextBlock Text="{Binding WeakPasswordCount}" FontSize="16" FontWeight="Bold"
                                      Foreground="#F59E0B"/>
                            <TextBlock Text="Weak" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>

                        <StackPanel Margin="16,0,0,0">
                            <TextBlock Text="{Binding DuplicateCount}" FontSize="16" FontWeight="Bold"
                                      Foreground="#EF4444"/>
                            <TextBlock Text="Duplicates" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Password Entries List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <Border Background="{DynamicResource CardBg}" Margin="24,0,24,24" CornerRadius="0,0,12,12"
                       BorderBrush="{DynamicResource BorderClr}" BorderThickness="0,1,0,0" Padding="24,16">
                    
                    <StackPanel>
                        <!-- Empty State -->
                        <Grid Visibility="{Binding HasNoEntries, Converter={StaticResource BoolToVisibilityConverter}}"
                             Height="200">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🔐" FontSize="48" HorizontalAlignment="Center"/>
                                <TextBlock Text="No passwords stored" FontSize="14" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Add your first password to get started" FontSize="12"
                                          Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Entries List -->
                        <ItemsControl ItemsSource="{Binding FilteredEntries}" Visibility="{Binding HasEntries, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF111B2E" CornerRadius="10" Padding="16" Margin="0,0,0,10"
                                           BorderBrush="#FF1E3A5F" BorderThickness="1" Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Entry Info -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                                          Foreground="{DynamicResource TextPrimary}"/>
                                                
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="👤" FontSize="11"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Username}" FontSize="11"
                                                              Foreground="{DynamicResource TextSecondary}"
                                                              TextTrimming="CharacterEllipsis"/>
                                                    
                                                    <TextBlock Grid.Column="2" Text="🌐" FontSize="11" Margin="16,0,0,0"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Website}" FontSize="11"
                                                              Foreground="{DynamicResource TextSecondary}"
                                                              TextTrimming="CharacterEllipsis" Margin="6,0,0,0"/>
                                                </Grid>

                                                <TextBlock Text="{Binding Category}" FontSize="10"
                                                          Foreground="{DynamicResource TextMuted}"/>
                                            </StackPanel>

                                            <!-- Strength & Date -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,24,0">
                                                <Border CornerRadius="4" Padding="8,4">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding PasswordStrength, Converter={StaticResource StrengthColorConverter}}"/>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding PasswordStrength}" FontSize="11"
                                                              FontWeight="SemiBold" Foreground="#FFFFFF"
                                                              HorizontalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding CreatedLabel}" FontSize="10"
                                                          Foreground="{DynamicResource TextMuted}"
                                                          HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Actions -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                       VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.CopyPasswordCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}" Height="32" Width="32"
                                                       Background="{DynamicResource HoverBg}" BorderThickness="0"
                                                       ToolTip="Copy Password">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <TextBlock Text="📋" FontSize="14"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.ToggleShowPasswordCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}" Height="32" Width="32"
                                                       Background="{DynamicResource HoverBg}" BorderThickness="0"
                                                       ToolTip="Toggle Show">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <TextBlock Text="{Binding ShowPassword, Converter={StaticResource BoolToEyeIconConverter}}"
                                                              FontSize="14"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}" Height="32" Width="32"
                                                       Background="#FF1E1E1E" BorderThickness="0"
                                                       ToolTip="Delete Entry"
                                                       Foreground="#EF4444">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <TextBlock Text="🗑️" FontSize="14"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
