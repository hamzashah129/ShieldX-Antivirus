<UserControl x:Class="ShieldX.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- Teal button style -->
        <Style x:Key="TealBtn" TargetType="Button">
            <Setter Property="Background" Value="#00E5CC"/>
            <Setter Property="Foreground" Value="#0D1117"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Purple button -->
        <Style x:Key="PurpleBtn" TargetType="Button" 
               BasedOn="{StaticResource TealBtn}">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Orange button -->
        <Style x:Key="OrangeBtn" TargetType="Button"
               BasedOn="{StaticResource TealBtn}">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Red button -->
        <Style x:Key="RedBtn" TargetType="Button"
               BasedOn="{StaticResource TealBtn}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Card style -->
        <Style x:Key="ScanCard" TargetType="Border">
            <Setter Property="Background" Value="#161B27"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="6,0"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="24,20,24,10">
            <TextBlock Text="Scan" FontSize="26" FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Detect and remove threats from your system"
                       Foreground="{DynamicResource TextSecondary}" FontSize="13" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Content area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,0,24,24">

                <!-- ══ STATE 1: SCAN CARDS ══ -->
                <Grid Visibility="{Binding ShowCards, 
                    Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Quick Scan Card -->
                    <Border Grid.Column="0" Style="{StaticResource ScanCard}"
                            BorderBrush="#00E5CC" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="⚡" FontSize="28" 
                                       Foreground="#00E5CC"/>
                            <TextBlock Text="Quick Scan" FontSize="18"
                                       FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="~1-2 minutes" Foreground="#00E5CC"
                                       FontSize="12" Margin="0,2,0,0"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,12,0,16"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                       Text="Scans Desktop, Downloads, Startup and Temp folders for threats."/>
                            <Button Content="Start Quick Scan →"
                                    Style="{StaticResource TealBtn}"
                                    Command="{Binding QuickScanCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- Full Scan Card -->
                    <Border Grid.Column="1" Style="{StaticResource ScanCard}">
                        <StackPanel>
                            <TextBlock Text="🛡" FontSize="28"
                                       Foreground="#7C3AED"/>
                            <TextBlock Text="Full Scan" FontSize="18"
                                       FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="~30+ minutes" Foreground="#7C3AED"
                                       FontSize="12" Margin="0,2,0,0"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,12,0,16"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                       Text="Scans all local drives and every file on your system."/>
                            <Button Content="Start Full Scan →"
                                    Style="{StaticResource PurpleBtn}"
                                    Command="{Binding FullScanCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- Custom Scan Card -->
                    <Border Grid.Column="2" Style="{StaticResource ScanCard}">
                        <StackPanel>
                            <TextBlock Text="📁" FontSize="28"
                                       Foreground="#F59E0B"/>
                            <TextBlock Text="Custom Scan" FontSize="18"
                                       FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="You choose" Foreground="#F59E0B"
                                       FontSize="12" Margin="0,2,0,0"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,12,0,16"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                       Text="Select a specific folder or file to scan."/>
                            <Button Content="Browse &amp; Scan →"
                                    Style="{StaticResource OrangeBtn}"
                                    Command="{Binding BrowseScanCommand}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ══ STATE 2: SCANNING IN PROGRESS ══ -->
                <Border Visibility="{Binding ShowScanning, 
                            Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource CardBg}" CornerRadius="10" 
                        Padding="30" Margin="0,0,0,16">
                    <StackPanel>

                        <!-- Spinning ring animation -->
                        <Grid Width="80" Height="80" 
                              HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse Width="80" Height="80"
                                     Stroke="#1E293B" StrokeThickness="5"/>
                            <Ellipse Width="80" Height="80"
                                     Stroke="#00E5CC" StrokeThickness="5"
                                     StrokeDashArray="60 200"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="SpinTransform"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetName="SpinTransform"
                                                    Storyboard.TargetProperty="Angle"
                                                    From="0" To="360"
                                                    Duration="0:0:1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="🛡" FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="{Binding ScanTypeName, 
                                       StringFormat='Running {0}...'}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center"/>

                        <!-- Progress bar -->
                        <Grid Margin="0,16,0,8">
                            <ProgressBar Value="{Binding ScanPercent}"
                                         Maximum="100" Height="8"
                                         Background="{DynamicResource HoverBg}">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush>
                                        <GradientStop Color="#00E5CC" Offset="0"/>
                                        <GradientStop Color="#7C3AED" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </Grid>

                        <!-- Stats row -->
                        <UniformGrid Columns="3" Margin="0,8,0,12">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Files Scanned"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding FilesScanned, 
                                               StringFormat='{}{0:N0}'}"
                                           Foreground="#00E5CC" FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Threats Found"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ThreatsFound}"
                                           Foreground="#EF4444" FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Time Elapsed"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DurationText}"
                                           Foreground="{DynamicResource TextPrimary}" FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </UniformGrid>

                        <!-- Current file being scanned -->
                        <Border Background="{DynamicResource AppBg}" CornerRadius="6" 
                                Padding="12,8">
                            <TextBlock Text="{Binding CurrentFile}"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>

                        <!-- Cancel button -->
                        <Button Content="Cancel Scan"
                                Style="{StaticResource RedBtn}"
                                Command="{Binding CancelScanCommand}"
                                Width="140" Margin="0,16,0,0"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ══ STATE 3: SCAN RESULTS ══ -->
                <StackPanel Visibility="{Binding ShowResult,
                                Converter={StaticResource BoolToVis}}">

                    <!-- Result summary card -->
                    <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                            Padding="30" Margin="0,0,0,16">
                        <StackPanel>

                            <!-- Clean result -->
                            <StackPanel HorizontalAlignment="Center"
                                        Visibility="{Binding IsClean,
                                            Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="✔" FontSize="48"
                                           Foreground="#10B981"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No Threats Found"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}" Margin="0,8,0,4"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Your system is clean and protected"
                                           Foreground="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Threats found result -->
                            <StackPanel HorizontalAlignment="Center"
                                        Visibility="{Binding HasThreats,
                                            Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="⚠" FontSize="48"
                                           Foreground="#EF4444"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ThreatsFound,
                                               StringFormat='{}{0} Threat(s) Found!'}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="#EF4444" Margin="0,8,0,4"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Threats detected — review and quarantine below"
                                           Foreground="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Stats row -->
                            <UniformGrid Columns="4" Margin="0,24,0,16">
                                <StackPanel Margin="8,0">
                                    <TextBlock Text="Files Scanned"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding FilesScanned,
                                                   StringFormat='{}{0:N0}'}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="18"/>
                                </StackPanel>
                                <StackPanel Margin="8,0">
                                    <TextBlock Text="Scan Type"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding ScanTypeName}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="18"/>
                                </StackPanel>
                                <StackPanel Margin="8,0">
                                    <TextBlock Text="Duration"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding DurationText}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="18"/>
                                </StackPanel>
                                <StackPanel Margin="8,0">
                                    <TextBlock Text="Completed"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding CompletedText}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="18"/>
                                </StackPanel>
                            </UniformGrid>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Button Content="Scan Again"
                                        Style="{StaticResource TealBtn}"
                                        Command="{Binding ScanAgainCommand}"
                                        Width="130" Margin="6,0"/>
                                <Button Content="Quarantine All Threats"
                                        Style="{StaticResource RedBtn}"
                                        Command="{Binding QuarantineAllCommand}"
                                        Width="170" Margin="6,0"
                                        Visibility="{Binding HasThreats,
                                            Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Detected threats list -->
                    <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                            Padding="20" Margin="0,0,0,16"
                            Visibility="{Binding HasThreats,
                                Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource TextPrimary}" FontSize="15"
                                       FontWeight="Bold" Margin="0,0,0,12">
                                <Run Text="Detected Threats ("/>
                                <Run Text="{Binding ThreatsFound}"/>
                                <Run Text=")"/>
                            </TextBlock>

                            <DataGrid ItemsSource="{Binding ThreatsList}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      Background="Transparent"
                                      RowBackground="{DynamicResource AppBg}"
                                      AlternatingRowBackground="{DynamicResource AltRowBg}"
                                      Foreground="{DynamicResource TextPrimary}"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#1E293B"
                                      MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="File Name"
                                        Binding="{Binding FileName}"
                                        Width="150"/>
                                    <DataGridTextColumn Header="Threat"
                                        Binding="{Binding ThreatName}"
                                        Width="180"/>
                                    <DataGridTextColumn Header="Severity"
                                        Binding="{Binding Severity}"
                                        Width="80"/>
                                    <DataGridTextColumn Header="Path"
                                        Binding="{Binding FilePath}"
                                        Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Recent Scans -->
                    <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Recent Scans"
                                       Foreground="{DynamicResource TextPrimary}" FontSize="15"
                                       FontWeight="Bold" Margin="0,0,0,12"/>
                            <DataGrid ItemsSource="{Binding RecentScans}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      Background="Transparent"
                                      RowBackground="{DynamicResource AppBg}"
                                      AlternatingRowBackground="{DynamicResource AltRowBg}"
                                      Foreground="{DynamicResource TextPrimary}"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#1E293B"
                                      MaxHeight="250">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Type"
                                        Binding="{Binding ScanType}"
                                        Width="80"/>
                                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding StartTime,
                                            StringFormat='{}{0:MM/dd/yyyy}'}"
                                        Width="90"/>
                                    <DataGridTextColumn Header="Time"
                                        Binding="{Binding StartTime,
                                            StringFormat='{}{0:hh:mm tt}'}"
                                        Width="80"/>
                                    <DataGridTextColumn Header="Files"
                                        Binding="{Binding FilesScanned,
                                            StringFormat='{}{0:N0}'}"
                                        Width="80"/>
                                    <DataGridTextColumn Header="Threats"
                                        Binding="{Binding ThreatsFound}"
                                        Width="70"/>
                                    <DataGridTextColumn Header="Duration"
                                        Binding="{Binding Duration}"
                                        Width="80"/>
                                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Recent scans shown on cards state too -->
                <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                        Padding="20" Margin="0,16,0,0"
                        Visibility="{Binding ShowCards,
                            Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Recent Scans"
                                   Foreground="{DynamicResource TextPrimary}" FontSize="15"
                                   FontWeight="Bold" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding RecentScans}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  Background="Transparent"
                                  RowBackground="{DynamicResource AppBg}"
                                  AlternatingRowBackground="{DynamicResource AltRowBg}"
                                  Foreground="{DynamicResource TextPrimary}"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#1E293B"
                                  MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Type"
                                    Binding="{Binding ScanType}" Width="80"/>
                                <DataGridTextColumn Header="Date"
                                    Binding="{Binding StartTime,
                                        StringFormat='{}{0:MM/dd/yyyy}'}"
                                    Width="90"/>
                                <DataGridTextColumn Header="Time"
                                    Binding="{Binding StartTime,
                                        StringFormat='{}{0:hh:mm tt}'}"
                                    Width="80"/>
                                <DataGridTextColumn Header="Files"
                                    Binding="{Binding FilesScanned,
                                        StringFormat='{}{0:N0}'}"
                                    Width="80"/>
                                <DataGridTextColumn Header="Threats"
                                    Binding="{Binding ThreatsFound}"
                                    Width="70"/>
                                <DataGridTextColumn Header="Duration"
                                    Binding="{Binding Duration}" Width="80"/>
                                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="No scan history yet. Run your first scan above."
                                   Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,0"
                                   Visibility="{Binding HasNoHistory,
                                       Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
