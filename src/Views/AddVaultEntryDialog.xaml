<Window x:Class="ShieldX.Views.AddVaultEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Password Entry"
        Width="420" Height="360"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">
    <Border CornerRadius="12"
            Background="{DynamicResource CardBg}"
            BorderBrush="{DynamicResource BorderClr}"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#000" Opacity="0.6"
                              BlurRadius="30" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Accent top -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,0">
                        <GradientStop Color="#00E5CC" Offset="0"/>
                        <GradientStop Color="#7C3AED" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Form -->
            <StackPanel Grid.Row="1" Margin="28,20">
                <TextBlock Text="➕  Add Password Entry"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="16" FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Website / App Name"
                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                           Margin="0,0,0,5"/>
                <Border Background="{DynamicResource AppBg}" CornerRadius="7"
                        BorderBrush="{DynamicResource BorderClr}" BorderThickness="1"
                        Margin="0,0,0,12">
                    <TextBox x:Name="TxtSite"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderThickness="0"
                             Padding="12,9" FontSize="13"/>
                </Border>

                <TextBlock Text="Username / Email"
                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                           Margin="0,0,0,5"/>
                <Border Background="{DynamicResource AppBg}" CornerRadius="7"
                        BorderBrush="{DynamicResource BorderClr}" BorderThickness="1"
                        Margin="0,0,0,12">
                    <TextBox x:Name="TxtUsername"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderThickness="0"
                             Padding="12,9" FontSize="13"/>
                </Border>

                <TextBlock Text="Password"
                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                           Margin="0,0,0,5"/>
                <Border Background="{DynamicResource AppBg}" CornerRadius="7"
                        BorderBrush="{DynamicResource BorderClr}" BorderThickness="1"
                        Margin="0,0,0,12">
                    <PasswordBox x:Name="TxtPassword"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimary}"
                                 BorderThickness="0"
                                 Padding="12,9" FontSize="13"/>
                </Border>

                <TextBlock Text="Category (optional)"
                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                           Margin="0,0,0,5"/>
                <Border Background="{DynamicResource AppBg}" CornerRadius="7"
                        BorderBrush="{DynamicResource BorderClr}" BorderThickness="1">
                    <TextBox x:Name="TxtCategory"
                             Text="General"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderThickness="0"
                             Padding="12,9" FontSize="13"/>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="{DynamicResource AppBg}"
                    CornerRadius="0,0,12,12" Padding="20,0">
                <Grid>
                    <Button Content="Cancel"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Padding="20,10"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondary}"
                            BorderBrush="{DynamicResource BorderClr}"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="Cancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="💾  Save Entry"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Padding="20,10"
                            Foreground="#0D1117"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Save_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="#00E5CC"
                                              Offset="0"/>
                                <GradientStop Color="#00C4AD"
                                              Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

